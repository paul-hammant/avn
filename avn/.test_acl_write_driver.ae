// Aether driver for write-side ACL enforcement + copy guard.
// Round 249. Migrated from avn/test_acl_write.sh.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string

extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/bash", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    avn_bin = os_getenv("AVN_BIN")
    port    = os_getenv("TEST_ACL_WRITE_PORT")
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    token   = "test-super-token-7-2"

    // (A) super sets +alice:rw +chuck:r -* on src
    acl_set = string.concat("SVN_SUPERUSER_TOKEN=", token)
    acl_set = string.concat(acl_set, " ")
    acl_set = string.concat(acl_set, avn_bin)
    acl_set = string.concat(acl_set, " acl set ")
    acl_set = string.concat(acl_set, url)
    acl_set = string.concat(acl_set, " src '+alice:rw' '+chuck:r' '-*' >/dev/null")

    // helper: build a url-flag commit cmd with given user prefix and add-file content
    // returns count of "Committed revision" lines via grep | wc -l
    commit_count = string.concat(avn_bin, " commit ")
    commit_count = string.concat(commit_count, url)

    // (B) alice can commit in src
    alice_commit = string.concat("SVN_USER=alice ", commit_count)
    alice_commit = string.concat(alice_commit, " --author alice --log 'alice adds' --add-file 'src/alice.txt=hello' 2>&1 | grep -c 'Committed revision' || true")

    // (C) bob denied
    bob_commit = string.concat("SVN_USER=bob ", commit_count)
    bob_commit = string.concat(bob_commit, " --author bob --log 'bob tries' --add-file 'src/bob.txt=nope' 2>&1 | grep -c 'Committed revision' || true")

    // (D) chuck (r-only) refused write
    chuck_commit = string.concat("SVN_USER=chuck ", commit_count)
    chuck_commit = string.concat(chuck_commit, " --author chuck --log 'chuck tries' --add-file 'src/chuck.txt=readonly' 2>&1 | grep -c 'Committed revision' || true")

    chuck_cat = string.concat("SVN_USER=chuck ", avn_bin)
    chuck_cat = string.concat(chuck_cat, " cat ")
    chuck_cat = string.concat(chuck_cat, url)
    chuck_cat = string.concat(chuck_cat, " src/alice.txt")

    // (E) anon refused at src
    anon_commit_src = string.concat(commit_count, " --author anon --log 'anon tries' --add-file 'src/anon.txt=noname' 2>&1 | grep -c 'Committed revision' || true")

    // anon can commit at root
    anon_commit_root = string.concat(commit_count, " --author anon --log 'anon outside src' --add-file 'public.txt=ok' 2>&1 | grep -c 'Committed revision' || true")

    // (F) bob can't self-elevate
    bob_self_elev = string.concat("SVN_USER=bob ", avn_bin)
    bob_self_elev = string.concat(bob_self_elev, " acl set ")
    bob_self_elev = string.concat(bob_self_elev, url)
    bob_self_elev = string.concat(bob_self_elev, " src '+bob:rw' 2>&1 | grep -c 'Committed revision' || true")

    // (G) super bypasses
    super_commit = string.concat("SVN_SUPERUSER_TOKEN=", token)
    super_commit = string.concat(super_commit, " ")
    super_commit = string.concat(super_commit, commit_count)
    super_commit = string.concat(super_commit, " --author super --log 'super in src' --add-file 'src/super.txt=ok' 2>&1 | grep -c 'Committed revision' || true")

    // copy guard
    bob_copy = string.concat("SVN_USER=bob ", avn_bin)
    bob_copy = string.concat(bob_copy, " cp ")
    bob_copy = string.concat(bob_copy, url)
    bob_copy = string.concat(bob_copy, "/src ")
    bob_copy = string.concat(bob_copy, url)
    bob_copy = string.concat(bob_copy, "/bob-stolen --author bob --log 'steal attempt' 2>&1 | grep -c 'Committed revision' || true")

    super_copy = string.concat("SVN_SUPERUSER_TOKEN=", token)
    super_copy = string.concat(super_copy, " ")
    super_copy = string.concat(super_copy, avn_bin)
    super_copy = string.concat(super_copy, " cp ")
    super_copy = string.concat(super_copy, url)
    super_copy = string.concat(super_copy, "/src ")
    super_copy = string.concat(super_copy, url)
    super_copy = string.concat(super_copy, "/src-mirror --author super --log 'super copies' 2>&1 | grep -c 'Committed revision' || true")

    aeocha.describe(fw, "write-side ACL + copy guard") {

        aeocha.it("(A) super sets ACL: +alice:rw +chuck:r -* on src") callback {
            _, st, _ = sh(acl_set)
            aeocha.expect_exit(fw, st, 0, "acl set exit 0")
        }

        aeocha.it("(B) alice can commit in src") callback {
            out, _, _ = sh(alice_commit)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }

        aeocha.it("(C) bob refused at src") callback {
            out, _, _ = sh(bob_commit)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(D) chuck (read-only) refused write to src") callback {
            out, _, _ = sh(chuck_commit)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(D) chuck can still read src/alice.txt") callback {
            out, _, _ = sh(chuck_cat)
            aeocha.expect_stdout_contains(fw, out, "hello", "chuck reads")
        }

        aeocha.it("(E) anon refused at src") callback {
            out, _, _ = sh(anon_commit_src)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(E) anon can commit at repo root (no ACL)") callback {
            out, _, _ = sh(anon_commit_root)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }

        aeocha.it("(F) bob can't self-elevate via acl set") callback {
            out, _, _ = sh(bob_self_elev)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(G) super-user commits in src bypassing ACL") callback {
            out, _, _ = sh(super_commit)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }

        aeocha.it("copy guard: bob can't copy denied subtree") callback {
            out, _, _ = sh(bob_copy)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("copy guard: super-user copies denied subtree") callback {
            out, _, _ = sh(super_copy)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }
    }

    aeocha.run_summary(fw)
}
