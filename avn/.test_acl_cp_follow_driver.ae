//
// Aether driver for `avn cp` ACL gate + auto-follow.
// Round 252. Migrated from avn/test_acl_cp_follow.sh.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string

extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/bash", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    avn_bin = os_getenv("AVN_BIN")
    port    = os_getenv("TEST_ACL_CP_FOLLOW_PORT")
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    base    = string.concat("http://127.0.0.1:", string.concat(port, "/repos/demo"))
    wc      = "/tmp/avn_test_cpacl_wc"
    token   = "cpacl-token"

    // r4: add nested
    setup = string.concat("rm -rf ", wc)
    setup = string.concat(setup, " && ")
    setup = string.concat(setup, avn_bin)
    setup = string.concat(setup, " checkout ")
    setup = string.concat(setup, url)
    setup = string.concat(setup, " ")
    setup = string.concat(setup, wc)
    setup = string.concat(setup, " >/dev/null && cd ")
    setup = string.concat(setup, wc)
    setup = string.concat(setup, " && mkdir -p src/nested && echo 'nested content' > src/nested/note.txt && ")
    setup = string.concat(setup, avn_bin)
    setup = string.concat(setup, " add src/nested >/dev/null && ")
    setup = string.concat(setup, avn_bin)
    setup = string.concat(setup, " add src/nested/note.txt >/dev/null && ")
    setup = string.concat(setup, avn_bin)
    setup = string.concat(setup, " commit --author admin --log 'add nested' >/dev/null")

    // (A) acl set src +alice:rw +chuck:r -*  (r5)
    acl_set_src = string.concat("SVN_SUPERUSER_TOKEN=", token)
    acl_set_src = string.concat(acl_set_src, " ")
    acl_set_src = string.concat(acl_set_src, avn_bin)
    acl_set_src = string.concat(acl_set_src, " acl set ")
    acl_set_src = string.concat(acl_set_src, url)
    acl_set_src = string.concat(acl_set_src, " src '+alice:rw' '+chuck:r' '-*' >/dev/null")

    // alice cp src → src-branch (r6) — count "Committed revision"
    alice_cp = string.concat("SVN_USER=alice ", avn_bin)
    alice_cp = string.concat(alice_cp, " cp ")
    alice_cp = string.concat(alice_cp, url)
    alice_cp = string.concat(alice_cp, "/src ")
    alice_cp = string.concat(alice_cp, url)
    alice_cp = string.concat(alice_cp, "/src-branch --author alice --log 'alice branches' 2>&1 | grep -c 'Committed revision' || true")

    // (F) bob denied on src-branch via curl X-Svnae-User
    bob_branch_curl = string.concat("curl -s -o /dev/null -w '%{http_code}' -H 'X-Svnae-User: bob' ", base)
    bob_branch_curl = string.concat(bob_branch_curl, "/rev/6/cat/src-branch/nested/note.txt")

    alice_branch_curl = string.concat("curl -s -o /dev/null -w '%{http_code}' -H 'X-Svnae-User: alice' ", base)
    alice_branch_curl = string.concat(alice_branch_curl, "/rev/6/cat/src-branch/nested/note.txt")

    // (B) bob's cp refused
    bob_cp = string.concat("SVN_USER=bob ", avn_bin)
    bob_cp = string.concat(bob_cp, " cp ")
    bob_cp = string.concat(bob_cp, url)
    bob_cp = string.concat(bob_cp, "/src ")
    bob_cp = string.concat(bob_cp, url)
    bob_cp = string.concat(bob_cp, "/bob-branch --author bob --log 'bob steal' 2>&1 | grep -c 'Committed revision' || true")

    // (C) chuck (r-only) cp refused
    chuck_cp = string.concat("SVN_USER=chuck ", avn_bin)
    chuck_cp = string.concat(chuck_cp, " cp ")
    chuck_cp = string.concat(chuck_cp, url)
    chuck_cp = string.concat(chuck_cp, "/src ")
    chuck_cp = string.concat(chuck_cp, url)
    chuck_cp = string.concat(chuck_cp, "/chuck-branch --author chuck --log 'chuck branch' 2>&1 | grep -c 'Committed revision' || true")

    // (D) anon cp refused
    anon_cp = string.concat(avn_bin, " cp ")
    anon_cp = string.concat(anon_cp, url)
    anon_cp = string.concat(anon_cp, "/src ")
    anon_cp = string.concat(anon_cp, url)
    anon_cp = string.concat(anon_cp, "/anon-branch --author anon --log 'anon branch' 2>&1 | grep -c 'Committed revision' || true")

    // (E) super cp succeeds (r7)
    super_cp = string.concat("SVN_SUPERUSER_TOKEN=", token)
    super_cp = string.concat(super_cp, " ")
    super_cp = string.concat(super_cp, avn_bin)
    super_cp = string.concat(super_cp, " cp ")
    super_cp = string.concat(super_cp, url)
    super_cp = string.concat(super_cp, "/src ")
    super_cp = string.concat(super_cp, url)
    super_cp = string.concat(super_cp, "/super-branch --author super --log 'super branch' 2>&1 | grep -c 'Committed revision' || true")

    bob_super_branch_curl = string.concat("curl -s -o /dev/null -w '%{http_code}' -H 'X-Svnae-User: bob' ", base)
    bob_super_branch_curl = string.concat(bob_super_branch_curl, "/rev/7/cat/super-branch/nested/note.txt")

    // (G) nested ACL on src/nested (r8) then alice cp → src-branch2 (r9)
    acl_nested = string.concat("SVN_SUPERUSER_TOKEN=", token)
    acl_nested = string.concat(acl_nested, " ")
    acl_nested = string.concat(acl_nested, avn_bin)
    acl_nested = string.concat(acl_nested, " acl set ")
    acl_nested = string.concat(acl_nested, url)
    acl_nested = string.concat(acl_nested, " src/nested '+alice:rw' '-*' >/dev/null")

    alice_branch2 = string.concat("SVN_USER=alice ", avn_bin)
    alice_branch2 = string.concat(alice_branch2, " cp ")
    alice_branch2 = string.concat(alice_branch2, url)
    alice_branch2 = string.concat(alice_branch2, "/src ")
    alice_branch2 = string.concat(alice_branch2, url)
    alice_branch2 = string.concat(alice_branch2, "/src-branch2 --author alice --log 'branch2' 2>&1 | grep -c 'Committed revision' || true")

    nested_rebased_check = string.concat("curl -s -H 'X-Svnae-Superuser: ", token)
    nested_rebased_check = string.concat(nested_rebased_check, "' ")
    nested_rebased_check = string.concat(nested_rebased_check, base)
    nested_rebased_check = string.concat(nested_rebased_check, "/rev/9/acl/src-branch2/nested | grep -c '\"+alice:rw\"' || true")

    aeocha.describe(fw, "avn cp ACL gate + auto-follow") {

        aeocha.it("setup: r4 add nested") callback {
            _, st, _ = sh(setup)
            aeocha.expect_exit(fw, st, 0, "setup exit 0")
        }

        aeocha.it("(A) super sets ACL on src; alice copies → src-branch") callback {
            _, st1, _ = sh(acl_set_src)
            aeocha.expect_exit(fw, st1, 0, "acl set exit 0")
            out, _, _ = sh(alice_cp)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit (alice cp)")
        }

        aeocha.it("(F) auto-follow: bob denied on src-branch (404)") callback {
            out, _, _ = sh(bob_branch_curl)
            aeocha.expect_stdout_contains(fw, out, "404", "404 for bob")
        }

        aeocha.it("(F) alice allowed on src-branch (200)") callback {
            out, _, _ = sh(alice_branch_curl)
            aeocha.expect_stdout_contains(fw, out, "200", "200 for alice")
        }

        aeocha.it("(B) bob's cp refused") callback {
            out, _, _ = sh(bob_cp)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(C) chuck (r-only) cp refused") callback {
            out, _, _ = sh(chuck_cp)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(D) anonymous cp refused") callback {
            out, _, _ = sh(anon_cp)
            aeocha.expect_stdout_contains(fw, out, "0", "0 commits")
        }

        aeocha.it("(E) super cp succeeds") callback {
            out, _, _ = sh(super_cp)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }

        aeocha.it("(E/F) bob still denied on super-branch (404)") callback {
            out, _, _ = sh(bob_super_branch_curl)
            aeocha.expect_stdout_contains(fw, out, "404", "404 for bob on super-branch")
        }

        aeocha.it("(G) nested ACL set + alice cp → src-branch2") callback {
            _, st1, _ = sh(acl_nested)
            aeocha.expect_exit(fw, st1, 0, "acl nested exit 0")
            out, _, _ = sh(alice_branch2)
            aeocha.expect_stdout_contains(fw, out, "1", "1 commit")
        }

        aeocha.it("(G) nested ACL rebased onto src-branch2/nested") callback {
            out, _, _ = sh(nested_rebased_check)
            aeocha.expect_stdout_contains(fw, out, "1",
                "+alice:rw rule found on src-branch2/nested")
        }
    }

    aeocha.run_summary(fw)
}
