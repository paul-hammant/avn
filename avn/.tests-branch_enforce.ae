import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnadmin")
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_branch_enforce_driver.ae")
        output("test_branch_enforce_driver")

        binary_under_test(b, "avn") {
            path("target/avn/bin/avn")
        }

        fixture_seed(b, "test_branch_enforce") {
            path("/tmp/avn_aeb_test_branch_enforce_repo")
            seed_bin("target/avnserver/bin/avn-seed")
        }
        fixture_server(b, "test_branch_enforce") {
            bin("target/avnserver/bin/avnserver")
            args("demo $TEST_BRANCH_ENFORCE_PATH 9666 --superuser-token b82b-token")
            port(9666)
            ready_after_ms(1500)
        }
    }
}
