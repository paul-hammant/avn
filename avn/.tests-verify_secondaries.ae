import build
import aether
import aether (driver, output, binary_under_test, path)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnadmin")
    build.dep(b, "avnserver")

    aether.driver_test(b) {
        driver(".test_verify_secondaries_driver.ae")
        output("test_verify_secondaries_driver")

        // No fixture_seed/server — the driver owns the lifecycle since
        // it needs to restart the server mid-test (corrupt rep-cache.db
        // between server runs). It uses ADMIN_BIN to create the repo
        // with --algos sha256,sha1 and SERVER_BIN to spawn directly.
        binary_under_test(b, "svn") {
            path("target/avn/bin/svn")
        }
        binary_under_test(b, "admin") {
            path("target/avnadmin/bin/svnadmin")
        }
        binary_under_test(b, "server") {
            path("target/avnserver/bin/aether-svnserver")
        }
    }
}
