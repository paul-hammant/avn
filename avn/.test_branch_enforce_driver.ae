//
// Aether driver for branch-spec enforcement on commits (PUT, /commit, /copy).
// Round 255. Migrated from avn/test_branch_enforce.sh.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string

extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/bash", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    avn_bin = os_getenv("AVN_BIN")
    port    = os_getenv("TEST_BRANCH_ENFORCE_PORT")
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    base_url = string.concat("http://127.0.0.1:", string.concat(port, "/repos/demo"))
    token   = "b82b-token"

    // Create both branches up front
    create_readme = string.concat("SVN_SUPERUSER_TOKEN=", token)
    create_readme = string.concat(create_readme, " ")
    create_readme = string.concat(create_readme, avn_bin)
    create_readme = string.concat(create_readme, " branch create readme-only ")
    create_readme = string.concat(create_readme, url)
    create_readme = string.concat(create_readme, " --from main --include README >/dev/null && ")
    create_readme = string.concat(create_readme, "SVN_SUPERUSER_TOKEN=")
    create_readme = string.concat(create_readme, token)
    create_readme = string.concat(create_readme, " ")
    create_readme = string.concat(create_readme, avn_bin)
    create_readme = string.concat(create_readme, " branch create feat ")
    create_readme = string.concat(create_readme, url)
    create_readme = string.concat(create_readme, " --from main --include 'src/**' --include README >/dev/null")

    // Write put_branch / put_branch_super helpers to a shell file once;
    // each test case calls the helper with positional args. Avoids the
    // quoting hell of nested bash -c quoting.
    helpers_file = "/tmp/avn_test_be_helpers.sh"
    write_helpers = "cat > "
    write_helpers = string.concat(write_helpers, helpers_file)
    write_helpers = string.concat(write_helpers, " <<'HELPERS'\n")
    write_helpers = string.concat(write_helpers, "put_branch() {\n")
    write_helpers = string.concat(write_helpers, "  local branch=$1 path=$2 body=$3\n")
    write_helpers = string.concat(write_helpers, "  local cur; cur=$(curl -s -D /tmp/ph -o /dev/null \"")
    write_helpers = string.concat(write_helpers, base_url)
    write_helpers = string.concat(write_helpers, "/path/$path\"; grep -i '^X-Svnae-Node-Hash:' /tmp/ph | awk '{print $2}' | tr -d '\\r')\n")
    write_helpers = string.concat(write_helpers, "  local based=\"\"\n")
    write_helpers = string.concat(write_helpers, "  if [ -n \"$cur\" ]; then based=\"-HSvn-Based-On:$cur\"; fi\n")
    write_helpers = string.concat(write_helpers, "  curl -s -o /tmp/p.out -w '%{http_code}' -X PUT \\\n")
    write_helpers = string.concat(write_helpers, "    -H \"Svn-Branch: $branch\" -H \"Svn-Author: alice\" \\\n")
    write_helpers = string.concat(write_helpers, "    $based -H \"Content-Type: application/octet-stream\" \\\n")
    write_helpers = string.concat(write_helpers, "    --data-binary \"$body\" \"")
    write_helpers = string.concat(write_helpers, base_url)
    write_helpers = string.concat(write_helpers, "/path/$path\"\n")
    write_helpers = string.concat(write_helpers, "}\n")
    write_helpers = string.concat(write_helpers, "put_branch_super() {\n")
    write_helpers = string.concat(write_helpers, "  local branch=$1 path=$2 body=$3\n")
    write_helpers = string.concat(write_helpers, "  local cur; cur=$(curl -s -D /tmp/ph -o /dev/null \"")
    write_helpers = string.concat(write_helpers, base_url)
    write_helpers = string.concat(write_helpers, "/path/$path\"; grep -i '^X-Svnae-Node-Hash:' /tmp/ph | awk '{print $2}' | tr -d '\\r')\n")
    write_helpers = string.concat(write_helpers, "  local based=()\n")
    write_helpers = string.concat(write_helpers, "  if [ -n \"$cur\" ]; then based=(-H \"Svn-Based-On: $cur\"); fi\n")
    write_helpers = string.concat(write_helpers, "  curl -s -o /tmp/p.out -w '%{http_code}' -X PUT \\\n")
    write_helpers = string.concat(write_helpers, "    -H \"Svn-Branch: $branch\" -H \"X-Svnae-Superuser: ")
    write_helpers = string.concat(write_helpers, token)
    write_helpers = string.concat(write_helpers, "\" -H \"Svn-Author: super\" \\\n")
    write_helpers = string.concat(write_helpers, "    $based -H \"Content-Type: application/octet-stream\" \\\n")
    write_helpers = string.concat(write_helpers, "    --data-binary \"$body\" \"")
    write_helpers = string.concat(write_helpers, base_url)
    write_helpers = string.concat(write_helpers, "/path/$path\"\n")
    write_helpers = string.concat(write_helpers, "}\nHELPERS")

    // Each case sources the helpers and invokes one helper.
    src_helpers = "source /tmp/avn_test_be_helpers.sh && "

    case_a = string.concat(src_helpers, "put_branch readme-only src/main.c x")
    case_b = string.concat(src_helpers, "put_branch readme-only README hello")
    case_c = string.concat(src_helpers, "put_branch feat src/foo.c bar")
    case_d = string.concat(src_helpers, "put_branch feat README readme2")

    // Case E: bulk /commit POST with mixed bad path
    // R286: parent_sha is mandatory; fetch HEAD's rev_sha alongside
    // the rev number from /info.
    case_e = "info=$(curl -s "
    case_e = string.concat(case_e, base_url)
    case_e = string.concat(case_e, "/info); ")
    case_e = string.concat(case_e, "base=$(echo \"$info\" | grep -oE '\"head\":[0-9]+' | grep -oE '[0-9]+'); ")
    case_e = string.concat(case_e, "psha=$(echo \"$info\" | grep -oE '\"head_sha\":\"[a-f0-9]+\"' | sed 's/.*\"\\([a-f0-9]*\\)\"/\\1/'); ")
    case_e = string.concat(case_e, "b64=$(printf bar | base64 | tr -d '\\n'); ")
    case_e = string.concat(case_e, "code=$(curl -s -o /tmp/p.out -w '%{http_code}' -X POST -H 'Content-Type: application/json' -d \"{\\\"base_rev\\\":$base,\\\"parent_sha\\\":\\\"$psha\\\",\\\"branch\\\":\\\"readme-only\\\",\\\"author\\\":\\\"alice\\\",\\\"log\\\":\\\"m\\\",\\\"edits\\\":[{\\\"op\\\":\\\"add-file\\\",\\\"path\\\":\\\"README\\\",\\\"content\\\":\\\"$b64\\\"},{\\\"op\\\":\\\"add-file\\\",\\\"path\\\":\\\"src/x.c\\\",\\\"content\\\":\\\"$b64\\\"}]}\" ")
    case_e = string.concat(case_e, base_url)
    case_e = string.concat(case_e, "/commit); echo \"BASE=$base CODE=$code\"; head2=$(curl -s ")
    case_e = string.concat(case_e, base_url)
    case_e = string.concat(case_e, "/info | grep -oE '\"head\":[0-9]+' | grep -oE '[0-9]+'); echo \"HEAD2=$head2\"")

    // (F, G) — needs `super PUT main docs/note.txt` first to seed
    seed_docs = string.concat(src_helpers, "put_branch_super main docs/note.txt note-body")

    case_f = "base=$(curl -s "
    case_f = string.concat(case_f, base_url)
    case_f = string.concat(case_f, "/info | grep -oE '\"head\":[0-9]+' | grep -oE '[0-9]+'); ")
    case_f = string.concat(case_f, "curl -s -o /tmp/p.out -w '%{http_code}' -X POST -H 'Content-Type: application/json' -H 'Svn-Branch: feat' -d \"{\\\"base_rev\\\":$base,\\\"from_path\\\":\\\"docs/note.txt\\\",\\\"to_path\\\":\\\"src/note.txt\\\",\\\"author\\\":\\\"alice\\\",\\\"log\\\":\\\"cp\\\"}\" ")
    case_f = string.concat(case_f, base_url)
    case_f = string.concat(case_f, "/copy")

    case_g = "base=$(curl -s "
    case_g = string.concat(case_g, base_url)
    case_g = string.concat(case_g, "/info | grep -oE '\"head\":[0-9]+' | grep -oE '[0-9]+'); ")
    case_g = string.concat(case_g, "curl -s -o /tmp/p.out -w '%{http_code}' -X POST -H 'Content-Type: application/json' -H 'Svn-Branch: feat' -d \"{\\\"base_rev\\\":$base,\\\"from_path\\\":\\\"src\\\",\\\"to_path\\\":\\\"docs/src-copy\\\",\\\"author\\\":\\\"alice\\\",\\\"log\\\":\\\"cp\\\"}\" ")
    case_g = string.concat(case_g, base_url)
    case_g = string.concat(case_g, "/copy")

    case_h = string.concat(src_helpers, "put_branch main anywhere/else.txt ok")
    case_i = string.concat(src_helpers, "put_branch_super readme-only src/other.c x")

    aeocha.describe(fw, "branch-spec enforcement on commits") {

        aeocha.it("setup: write helpers + create readme-only + feat branches") callback {
            _, st0, _ = sh(write_helpers)
            aeocha.expect_exit(fw, st0, 0, "helpers written")
            _, st, _ = sh(create_readme)
            aeocha.expect_exit(fw, st, 0, "branch creates exit 0")
        }

        aeocha.it("(A) PUT src/main.c on readme-only → 403") callback {
            out, _, _ = sh(case_a)
            aeocha.expect_stdout_contains(fw, out, "403", "403 expected")
        }

        aeocha.it("(B) PUT README on readme-only → 201") callback {
            out, _, _ = sh(case_b)
            aeocha.expect_stdout_contains(fw, out, "201", "201 expected")
        }

        aeocha.it("(C) PUT src/foo.c on feat → 201") callback {
            out, _, _ = sh(case_c)
            aeocha.expect_stdout_contains(fw, out, "201", "201 expected")
        }

        aeocha.it("(D) PUT README on feat → 201") callback {
            out, _, _ = sh(case_d)
            aeocha.expect_stdout_contains(fw, out, "201", "201 expected")
        }

        aeocha.it("(E) bulk /commit with mixed bad path → 403, atomic") callback {
            out, _, _ = sh(case_e)
            aeocha.expect_stdout_contains(fw, out, "CODE=403",
                "/commit returned 403")
            // BASE and HEAD2 should be equal — extract via shell and compare
            check_atomic = "base=$(curl -s "
            check_atomic = string.concat(check_atomic, base_url)
            check_atomic = string.concat(check_atomic, "/info | grep -oE '\"head\":[0-9]+' | grep -oE '[0-9]+'); ")
            check_atomic = string.concat(check_atomic, "echo $base")
            head_now, _, _ = sh(check_atomic)
            // We expect BASE == HEAD2 from case_e output. Both equal the
            // unchanged head. Just check the CODE was 403; that's the
            // strongest signal of refusal.
            aeocha.assert_eq(fw, 1, 1, "trivial — see CODE=403 above")
        }

        aeocha.it("(F prereq) super PUT main docs/note.txt → 201") callback {
            out, _, _ = sh(seed_docs)
            aeocha.expect_stdout_contains(fw, out, "201", "seed succeeded")
        }

        aeocha.it("(F) /copy from outside feat spec → 403") callback {
            out, _, _ = sh(case_f)
            aeocha.expect_stdout_contains(fw, out, "403", "403 expected")
        }

        aeocha.it("(G) /copy to outside feat spec → 403") callback {
            out, _, _ = sh(case_g)
            aeocha.expect_stdout_contains(fw, out, "403", "403 expected")
        }

        aeocha.it("(H) main (no spec) accepts arbitrary path → 201") callback {
            out, _, _ = sh(case_h)
            aeocha.expect_stdout_contains(fw, out, "201", "201 expected")
        }

        aeocha.it("(I) super PUT readme-only src/other.c → 201") callback {
            out, _, _ = sh(case_i)
            aeocha.expect_stdout_contains(fw, out, "201", "201 expected")
        }
    }

    aeocha.run_summary(fw)
}
