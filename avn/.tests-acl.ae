import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, env_var, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnadmin")
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_acl_driver.ae")
        output("test_acl_driver")

        binary_under_test(b, "svn") {
            path("target/avn/bin/svn")
        }

        fixture_seed(b, "test_acl") {
            path("/tmp/avn_aeb_test_acl_repo")
            seed_bin("target/avnserver/bin/svnae-seed")
        }
        fixture_server(b, "test_acl") {
            bin("target/avnserver/bin/aether-svnserver")
            // Token-auth: pass --superuser-token via args.
            args("demo $TEST_ACL_PATH 9540 --superuser-token test-super-token-42")
            port(9540)
            ready_after_ms(1500)
        }
    }
}
