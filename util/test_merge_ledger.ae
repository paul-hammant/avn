//
// Unit tests for repo_storage/merge_ledger.ae — Phase 1.1 of the
// merge-ledger architecture (replaces svn:mergeinfo). The ledger is
// a derived index over rev blobs, queried by wc_merge during sweep
// merges. Pre-avnadmin-create the schema is created lazily;
// post-create it's already in place.

import std.string
import repos

extern os_getpid_raw() -> int
extern system(cmd: string) -> int

extern merge_ledger_init_schema(repo: string) -> string

// Phase 1.2: rev blob `merged:` field encode/decode.
extern format_merged_field(source_branch: string, source_revs_packed: string) -> string
extern parse_merged_field(value: string) -> (string, string)
extern rev_blob_body(root: string, branch: string, props: string, acl: string,
                     prev: int, merged: string,
                     author: string, date: string, log: string) -> string

// Phase 1.3: txn merge metadata.
extern txn_new(base_rev: int) -> ptr
extern txn_free(t: ptr)
extern txn_merge_set_source(t: ptr, target_path: string,
                            source_branch: string, verb: int) -> int
extern txn_merge_record_rev(t: ptr, source_sha: string) -> int
extern txn_merge_target_path(t: ptr) -> string
extern txn_merge_source_branch(t: ptr) -> string
extern txn_merge_count(t: ptr) -> int
extern txn_merge_source_rev_at(t: ptr, i: int) -> string
extern txn_merge_verb(t: ptr) -> int
extern txn_merge_source_revs_packed(t: ptr) -> string
extern merge_ledger_record(repo: string,
                           rev_sha: string,
                           target_branch: string, source_branch: string,
                           source_revs_packed: string,
                           rev_num: int,
                           verb: int, author: string, ts: string) -> int
extern merge_ledger_is_integrated(repo: string,
                                  target_branch: string,
                                  source_branch: string,
                                  source_rev_sha: string) -> int
extern merge_ledger_is_integrated_as_of(repo: string,
                                        target_branch: string,
                                        source_branch: string,
                                        source_rev_sha: string,
                                        as_of_rev: int) -> int
extern merge_ledger_integrated_set(repo: string,
                                   target_branch: string,
                                   source_branch: string) -> string
extern merge_ledger_eligible_revs(repo: string,
                                  target_branch: string,
                                  source_branch: string,
                                  candidate_revs_packed: string) -> string

const VERB_APPLIED     = 0
const VERB_RECORD_ONLY = 1
const VERB_REVERSE     = 2

expect_int(label: string, got: int, want: int) -> int {
    if got == want { println("ok   ${label}: ${got}"); return 0 }
    println("FAIL ${label}: got ${got}, want ${want}")
    return 1
}

expect_str(label: string, got: string, want: string) -> int {
    if string.equals(got, want) == 1 { println("ok   ${label}"); return 0 }
    println("FAIL ${label}: got [${got}] want [${want}]")
    return 1
}

main() {
    fails = 0
    pid = os_getpid_raw()
    repo = "/tmp/test_mledger_${pid}"
    system("rm -rf ${repo}")
    system("mkdir -p ${repo}")

    // Eagerly install the schema (mirrors what avnadmin/create.ae
    // does inside create_bare_).
    err = merge_ledger_init_schema(repo)
    fails = fails + expect_str("merge_ledger_init_schema", err, "")

    // The ledger DB should now exist under $repo/merges.db.
    rc = system("test -f ${repo}/merges.db")
    fails = fails + expect_int("merges.db exists post-init", rc, 0)

    // Empty ledger: no revs integrated.
    fails = fails + expect_int("empty: not integrated",
        merge_ledger_is_integrated(repo, "release_a", "main",
            "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"),
        0)
    fails = fails + expect_str("empty: integrated_set",
        merge_ledger_integrated_set(repo, "release_a", "main"),
        "")

    // Record a single merge event with three source revs.
    sha_merge1 = "1111111111111111111111111111111111111111"
    sha_src_a  = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    sha_src_b  = "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    sha_src_c  = "cccccccccccccccccccccccccccccccccccccccc"
    packed_abc = "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n"

    rec = merge_ledger_record(repo, sha_merge1, "release_a", "main",
                              packed_abc, 10, VERB_APPLIED, "alice",
                              "2026-05-07T09:00:00Z")
    fails = fails + expect_int("record (a,b,c) into release_a from main", rec, 0)

    // Each source rev should now be integrated.
    fails = fails + expect_int("a integrated",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_src_a), 1)
    fails = fails + expect_int("b integrated",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_src_b), 1)
    fails = fails + expect_int("c integrated",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_src_c), 1)

    // Different target → not integrated.
    fails = fails + expect_int("a not in release_b",
        merge_ledger_is_integrated(repo, "release_b", "main", sha_src_a), 0)
    // Different source branch → not integrated.
    fails = fails + expect_int("a not from feature",
        merge_ledger_is_integrated(repo, "release_a", "feature", sha_src_a), 0)
    // Unknown sha → not integrated.
    sha_dead = "dddddddddddddddddddddddddddddddddddddddd"
    fails = fails + expect_int("d not integrated",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_dead), 0)

    // Eligible filter: of {a, d, b}, expect just {d}.
    candidates = "${sha_src_a}\n${sha_dead}\n${sha_src_b}\n"
    elig = merge_ledger_eligible_revs(repo, "release_a", "main", candidates)
    fails = fails + expect_str("eligible filters out merged", elig, "${sha_dead}\n")

    // integrated_set sorts SHAs ascending — a, b, c is the canonical order.
    iset = merge_ledger_integrated_set(repo, "release_a", "main")
    fails = fails + expect_str("integrated_set sorted",
        iset, "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n")

    // Idempotency: re-recording the same event is a no-op (INSERT OR IGNORE).
    rec2 = merge_ledger_record(repo, sha_merge1, "release_a", "main",
                               packed_abc, 10, VERB_APPLIED, "alice",
                               "2026-05-07T09:00:00Z")
    fails = fails + expect_int("re-record (idempotent)", rec2, 0)
    iset2 = merge_ledger_integrated_set(repo, "release_a", "main")
    fails = fails + expect_str("idempotent: integrated_set unchanged",
        iset2, "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n")

    // Second merge event integrating distinct SHAs into the same target.
    sha_merge2 = "2222222222222222222222222222222222222222"
    sha_src_d  = "eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee"
    rec3 = merge_ledger_record(repo, sha_merge2, "release_a", "main",
                               "${sha_src_d}\n", 11, VERB_APPLIED, "bob",
                               "2026-05-07T10:00:00Z")
    fails = fails + expect_int("record d into release_a", rec3, 0)
    fails = fails + expect_int("d integrated after second event",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_src_d), 1)

    // Record-only verb stores the row but for `avn merged` reporting
    // we'd want to distinguish; the integration check still says
    // "yes" (the rev was *considered*). That mirrors Perforce's
    // ignored verb — knowable via the merge_event row's `verb`
    // column. For the simple "is integrated" question, the answer
    // is yes.
    sha_merge3 = "3333333333333333333333333333333333333333"
    sha_blocked = "ffffffffffffffffffffffffffffffffffffffff"
    rec4 = merge_ledger_record(repo, sha_merge3, "release_a", "main",
                               "${sha_blocked}\n", 12, VERB_RECORD_ONLY,
                               "alice", "2026-05-07T11:00:00Z")
    fails = fails + expect_int("record-only of blocked sha", rec4, 0)
    fails = fails + expect_int("record-only counts as integrated for skip",
        merge_ledger_is_integrated(repo, "release_a", "main", sha_blocked), 1)

    // ---- Phase 1.2: rev blob `merged:` field encode/decode ------

    // Encoder: source + multiple SHAs → "src:sha1,sha2,sha3"
    enc_three = format_merged_field("main", "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n")
    fails = fails + expect_str("encode 3 SHAs",
        enc_three, "main:${sha_src_a},${sha_src_b},${sha_src_c}")

    // Encoder: empty source branch → ""
    fails = fails + expect_str("encode empty src → empty",
        format_merged_field("", "${sha_src_a}\n"), "")

    // Encoder: empty SHA list → ""
    fails = fails + expect_str("encode empty SHAs → empty",
        format_merged_field("main", ""), "")

    // Decoder: round-trip
    dec_src, dec_revs = parse_merged_field(enc_three)
    fails = fails + expect_str("decode src", dec_src, "main")
    fails = fails + expect_str("decode SHAs",
        dec_revs, "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n")

    // Decoder: malformed (no colon)
    bad_src, bad_revs = parse_merged_field("nocolon")
    fails = fails + expect_str("decode no colon → empty src", bad_src, "")
    fails = fails + expect_str("decode no colon → empty revs", bad_revs, "")

    // Decoder: empty value
    e_src, e_revs = parse_merged_field("")
    fails = fails + expect_str("decode empty value → empty src", e_src, "")
    fails = fails + expect_str("decode empty value → empty revs", e_revs, "")

    // rev_blob_body: with merged → field appears in body, retrievable
    // by repos.blobfield_get (the canonical reader downstream callers use).
    body_with = rev_blob_body("rsha", "release_a", "", "", 7, enc_three,
                              "alice", "2026-05-07T12:00:00Z", "merge log")
    got_merged = repos.blobfield_get(body_with, "merged")
    fails = fails + expect_str("rev_blob round-trip merged",
        got_merged, enc_three)

    // rev_blob_body: empty merged → no "merged:" line in body. Old
    // rev blobs round-trip exactly the same as before this round.
    body_no_merge = rev_blob_body("rsha", "main", "", "", 6, "",
                                  "bob", "2026-05-07T12:00:00Z", "non-merge log")
    no_merged = repos.blobfield_get(body_no_merge, "merged")
    fails = fails + expect_str("rev_blob_body omits merged: when empty",
        no_merged, "")

    // Other fields unaffected by merged: presence.
    fails = fails + expect_str("root unchanged",
        repos.blobfield_get(body_with, "root"), "rsha")
    fails = fails + expect_str("branch unchanged",
        repos.blobfield_get(body_with, "branch"), "release_a")
    fails = fails + expect_str("author unchanged",
        repos.blobfield_get(body_with, "author"), "alice")
    fails = fails + expect_str("log unchanged",
        repos.blobfield_get(body_with, "log"), "merge log")

    // ---- Phase 1.3: txn merge metadata round-trip ---------------

    // A fresh txn carries no merge metadata.
    t1 = txn_new(0)
    fails = fails + expect_str("fresh txn: no source",
        txn_merge_source_branch(t1), "")
    fails = fails + expect_int("fresh txn: no source revs",
        txn_merge_count(t1), 0)
    fails = fails + expect_int("fresh txn: verb defaults to APPLIED",
        txn_merge_verb(t1), VERB_APPLIED)
    fails = fails + expect_str("fresh txn: packed empty",
        txn_merge_source_revs_packed(t1), "")
    txn_free(t1)

    // Set source + record three revs, verify each accessor.
    t2 = txn_new(5)
    rs = txn_merge_set_source(t2, "release_a", "main", VERB_APPLIED)
    fails = fails + expect_int("txn_merge_set_source", rs, 0)
    txn_merge_record_rev(t2, sha_src_a)
    txn_merge_record_rev(t2, sha_src_b)
    txn_merge_record_rev(t2, sha_src_c)

    fails = fails + expect_str("txn target = release_a",
        txn_merge_target_path(t2), "release_a")
    fails = fails + expect_str("txn source = main",
        txn_merge_source_branch(t2), "main")
    fails = fails + expect_int("txn merge count = 3",
        txn_merge_count(t2), 3)
    fails = fails + expect_str("txn rev[0]",
        txn_merge_source_rev_at(t2, 0), sha_src_a)
    fails = fails + expect_str("txn rev[1]",
        txn_merge_source_rev_at(t2, 1), sha_src_b)
    fails = fails + expect_str("txn rev[2]",
        txn_merge_source_rev_at(t2, 2), sha_src_c)
    fails = fails + expect_int("txn verb",
        txn_merge_verb(t2), VERB_APPLIED)

    // packed shape feeds straight into format_merged_field.
    pk = txn_merge_source_revs_packed(t2)
    fails = fails + expect_str("txn packed",
        pk, "${sha_src_a}\n${sha_src_b}\n${sha_src_c}\n")

    enc_t2 = format_merged_field("main", pk)
    fails = fails + expect_str("encode txn → rev-blob field",
        enc_t2, "main:${sha_src_a},${sha_src_b},${sha_src_c}")

    txn_free(t2)

    // Bad inputs are rejected.
    t3 = txn_new(0)
    fails = fails + expect_int("set_source with empty branch",
        txn_merge_set_source(t3, "", "", VERB_APPLIED), 0 - 1)
    fails = fails + expect_int("record_rev with empty sha",
        txn_merge_record_rev(t3, ""), 0 - 1)
    fails = fails + expect_int("after rejected calls: still no source",
        txn_merge_count(t3), 0)
    txn_free(t3)

    // ---- Round 281: reverse-merge subtraction --------------------
    //
    // Scenarios:
    //   F1: forward(rN)                            → integrated
    //   F2: forward(rN), reverse(rN)               → NOT integrated, eligible
    //   F3: forward(rN), reverse(rN), forward(rN)  → integrated
    //   F4: forward(rN), reverse(rN) -- as_of mid  → integrated  (the
    //                                                 reverse hasn't
    //                                                 happened yet
    //                                                 at the as-of view)
    //
    // Each merge_event uses a distinct rev_sha; SHA pattern below is
    // arbitrary but unique. All target/source branches are `rev_t /
    // rev_s` to keep these scenarios isolated from earlier asserts.
    rev_target = "rev_t"
    rev_source = "rev_s"
    sha_fwd1 = "f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1f1"
    sha_rev1 = "0202020202020202020202020202020202020202"
    sha_fwd2 = "f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3f3"
    sha_x    = "1234567890abcdef1234567890abcdef12345678"

    // F1 — forward only.
    rec_f1 = merge_ledger_record(repo, sha_fwd1, rev_target, rev_source,
                                 "${sha_x}\n", 100, VERB_APPLIED, "carol",
                                 "2026-05-07T12:00:00Z")
    fails = fails + expect_int("F1: record forward", rec_f1, 0)
    fails = fails + expect_int("F1: x integrated",
        merge_ledger_is_integrated(repo, rev_target, rev_source, sha_x), 1)
    fails = fails + expect_str("F1: integrated_set has x",
        merge_ledger_integrated_set(repo, rev_target, rev_source),
        "${sha_x}\n")
    fails = fails + expect_str("F1: x not eligible",
        merge_ledger_eligible_revs(repo, rev_target, rev_source, "${sha_x}\n"),
        "")

    // F2 — reverse merge of x. After this, x should not be integrated
    // and should re-appear in the eligible set.
    rec_r1 = merge_ledger_record(repo, sha_rev1, rev_target, rev_source,
                                 "${sha_x}\n", 110, VERB_REVERSE, "carol",
                                 "2026-05-07T13:00:00Z")
    fails = fails + expect_int("F2: record reverse", rec_r1, 0)
    fails = fails + expect_int("F2: x not integrated after reverse",
        merge_ledger_is_integrated(repo, rev_target, rev_source, sha_x), 0)
    fails = fails + expect_str("F2: integrated_set excludes x",
        merge_ledger_integrated_set(repo, rev_target, rev_source), "")
    fails = fails + expect_str("F2: x is eligible again",
        merge_ledger_eligible_revs(repo, rev_target, rev_source, "${sha_x}\n"),
        "${sha_x}\n")

    // F3 — forward again. Latest verb wins → integrated.
    rec_f2 = merge_ledger_record(repo, sha_fwd2, rev_target, rev_source,
                                 "${sha_x}\n", 120, VERB_APPLIED, "carol",
                                 "2026-05-07T14:00:00Z")
    fails = fails + expect_int("F3: record forward again", rec_f2, 0)
    fails = fails + expect_int("F3: x integrated again after re-forward",
        merge_ledger_is_integrated(repo, rev_target, rev_source, sha_x), 1)
    fails = fails + expect_str("F3: integrated_set has x again",
        merge_ledger_integrated_set(repo, rev_target, rev_source),
        "${sha_x}\n")
    fails = fails + expect_str("F3: x no longer eligible",
        merge_ledger_eligible_revs(repo, rev_target, rev_source, "${sha_x}\n"),
        "")

    // F4 — as-of-rev between forward (rev_num=100) and reverse
    // (rev_num=110). The reverse hasn't happened in the as-of view
    // yet. Note: as_of uses the merge_ledger_is_integrated_as_of
    // entry point.
    fails = fails + expect_int("F4: as_of=105 (between F+R) → integrated",
        merge_ledger_is_integrated_as_of(repo, rev_target, rev_source,
                                         sha_x, 105), 1)
    // And as-of=115 (after reverse, before re-forward at 120) → not.
    fails = fails + expect_int("F4: as_of=115 (between R+F) → NOT integrated",
        merge_ledger_is_integrated_as_of(repo, rev_target, rev_source,
                                         sha_x, 115), 0)
    // And as-of=125 (after re-forward) → integrated.
    fails = fails + expect_int("F4: as_of=125 (after re-forward) → integrated",
        merge_ledger_is_integrated_as_of(repo, rev_target, rev_source,
                                         sha_x, 125), 1)

    // Cleanup.
    system("rm -rf ${repo}")

    if fails == 0 {
        println("test_merge_ledger: OK")
    } else {
        println("test_merge_ledger: ${fails} FAIL(s)")
        exit(1)
    }
}
