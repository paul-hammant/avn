// Test error chain, defined inline in the same file.
//
// Aether has no __FILE__/__LINE__ (AETHER_ISSUES.md #4), so every call
// site passes the location explicitly. `message` is still a reserved
// keyword, so we use `msg` for the message-text parameter.

extern error_create(code: int, msg: string, cause: ptr, file: string, line: int) -> ptr
extern error_code(err: ptr) -> int
extern error_message(err: ptr) -> string
extern error_cause(err: ptr) -> ptr
extern error_file(err: ptr) -> string
extern error_line(err: ptr) -> int
extern error_free(err: ptr)

const ERR_IO_OPEN     = 2001
const ERR_WC_CORRUPT  = 4001
const ERR_BAD_ARG     = 1001
const ERR_FS_CORRUPT  = 5001

err_create(code: int, msg: string, file: string, line: int) {
    return error_create(code, msg, 0, file, line)
}

err_wrap(cause: ptr, code: int, msg: string, file: string, line: int) {
    return error_create(code, msg, cause, file, line)
}

err_has_code(err: ptr, c: int) {
    e = err
    while e != 0 {
        if error_code(e) == c { return 1 }
        e = error_cause(e)
    }
    return 0
}

err_print_chain(err: ptr) {
    if err == 0 {
        println("(no error)")
        return
    }
    e = err
    while e != 0 {
        c = error_code(e)
        m = error_message(e)
        f = error_file(e)
        l = error_line(e)
        println("avn: E${c}: ${m}  [${f}:${l}]")
        e = error_cause(e)
    }
    return
}

main() {
    leaf = err_create(ERR_IO_OPEN, "open failed: permission denied",
                      "test_error.ae", 10)
    mid  = err_wrap(leaf, ERR_WC_CORRUPT,
                    "could not read pristine store",
                    "test_error.ae", 15)
    top  = err_wrap(mid,  ERR_BAD_ARG,
                    "avn status failed for /tmp/wc",
                    "test_error.ae", 20)

    err_print_chain(top)

    if err_has_code(top, ERR_IO_OPEN) == 0 {
        println("FAIL: expected chain to contain ERR_IO_OPEN")
        exit(1)
    }
    if err_has_code(top, ERR_FS_CORRUPT) == 1 {
        println("FAIL: chain should not contain ERR_FS_CORRUPT")
        exit(1)
    }

    error_free(top)

    // Null-safety: free(0) and accessors on 0 must not crash.
    error_free(0)
    if error_code(0) != 0 {
        println("FAIL: code(null) should be 0")
        exit(1)
    }

    println("test_error: OK")
}
