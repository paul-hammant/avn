// End-to-end test: create a repo, write blobs, verify rep-sharing,
// read blobs back, and verify zlib compression kicks in for compressible
// payloads and not for incompressible ones.

import std.fs
import std.string
import std.zlib
import ffi.openssl

// --- externs from subr shims ------------------------------------------------

// Round 176: std.zlib retired the C-side zlib_*/buf_*
// shim. zlib.deflate / zlib.inflate return (string, int, error) tuples;
// the previous opaque-buf handle dance is gone.

extern os_getpid_raw() -> int
// Round 185: switched to fs.read_binary (already shipped) — no
// more buf carrier, no manual free, length-aware return.

extern file_exists(path: string) -> int
extern dir_exists(path: string) -> int

import contrib.sqlite
import util

const SQLITE_ROW  = 100
const SQLITE_DONE = 101

const STORAGE_RAW  = 1
const STORAGE_ZLIB = 2

create_repo(path: string) {
    if dir_exists(path) == 1 { return 1 }
    if file_exists(path) == 1 { return 2 }
    merr = fs.mkdir_p(path)
    if string.length(merr) != 0 { return 10 }
    reps = "${path}/reps"
    merr = fs.mkdir_p(reps)
    if string.length(merr) != 0 { return 11 }
    rc = util.io_write_atomic("${path}/format", "svnae-fsfs-1\n", 13)
    if rc != 0 { return rc }
    db, oerr = sqlite.open("${path}/rep-cache.db")
    if string.length(oerr) > 0 { return 3 }
    err = sqlite.exec(db,
        "CREATE TABLE rep_cache (hash TEXT PRIMARY KEY, rel_path TEXT NOT NULL, uncompressed_size INT NOT NULL, storage INT NOT NULL)")
    sqlite.close(db)
    if string.length(err) > 0 { return 4 }
    return 0
}

rel_path_for_hash(sha1: string) {
    aa = string.substring(sha1, 0, 2)
    bb = string.substring(sha1, 2, 4)
    return "${aa}/${bb}/${sha1}.rep"
}

ensure_fanout_dirs(repo: string, sha1: string) {
    aa = string.substring(sha1, 0, 2)
    bb = string.substring(sha1, 2, 4)
    d = "${repo}/reps/${aa}/${bb}"
    merr = fs.mkdir_p(d)
    if string.length(merr) != 0 { return 1 }
    return 0
}

rep_cache_has(repo: string, sha1: string) {
    db, oerr = sqlite.open("${repo}/rep-cache.db")
    if string.length(oerr) > 0 { return 0 }
    stmt, perr = sqlite.prepare(db, "SELECT 1 FROM rep_cache WHERE hash = ?")
    if string.length(perr) > 0 { sqlite.close(db); return 0 }
    sqlite.bind_text(stmt, 1, sha1)
    rc, _ = sqlite.step(stmt, db)
    found = 0
    if rc == SQLITE_ROW { found = 1 }
    sqlite.finalize(stmt)
    sqlite.close(db)
    return found
}

rep_cache_lookup_storage(repo: string, sha1: string) {
    db, oerr = sqlite.open("${repo}/rep-cache.db")
    if string.length(oerr) > 0 { return 0 }
    stmt, _ = sqlite.prepare(db, "SELECT storage FROM rep_cache WHERE hash = ?")
    sqlite.bind_text(stmt, 1, sha1)
    rc, _ = sqlite.step(stmt, db)
    s = 0
    if rc == SQLITE_ROW { s = sqlite.column_int(stmt, 0) }
    sqlite.finalize(stmt)
    sqlite.close(db)
    return s
}

rep_cache_lookup_uncompressed_size(repo: string, sha1: string) {
    db, oerr = sqlite.open("${repo}/rep-cache.db")
    if string.length(oerr) > 0 { return 0 }
    stmt, _ = sqlite.prepare(db, "SELECT uncompressed_size FROM rep_cache WHERE hash = ?")
    sqlite.bind_text(stmt, 1, sha1)
    rc, _ = sqlite.step(stmt, db)
    v = 0
    if rc == SQLITE_ROW { v = sqlite.column_int(stmt, 0) }
    sqlite.finalize(stmt)
    sqlite.close(db)
    return v
}

rep_cache_insert(repo: string, sha1: string, rel_path: string,
                 uncompressed_size: int, storage: int) {
    db, oerr = sqlite.open("${repo}/rep-cache.db")
    if string.length(oerr) > 0 { return 1 }
    stmt, _ = sqlite.prepare(db,
        "INSERT INTO rep_cache (hash, rel_path, uncompressed_size, storage) VALUES (?, ?, ?, ?)")
    sqlite.bind_text(stmt, 1, sha1)
    sqlite.bind_text(stmt, 2, rel_path)
    sqlite.bind_int (stmt, 3, uncompressed_size)
    sqlite.bind_int (stmt, 4, storage)
    rc, _ = sqlite.step(stmt, db)
    sqlite.finalize(stmt)
    sqlite.close(db)
    if rc != SQLITE_DONE { return 2 }
    return 0
}

write_blob(repo: string, data: string) {
    n = string.length(data)
    sha1_copy = openssl.crypto_hash_hex("sha1", data, n)

    if rep_cache_has(repo, sha1_copy) == 1 { return sha1_copy }

    storage = STORAGE_RAW
    comp, clen, cerr = zlib.deflate(data, n, 6)
    use_zlib = 0
    if string.length(cerr) == 0 {
        if clen + 16 < n {
            storage = STORAGE_ZLIB
            use_zlib = 1
        }
    }

    storage_hdr = "R"
    if storage == STORAGE_ZLIB { storage_hdr = "Z" }

    ensure_fanout_dirs(repo, sha1_copy)
    rel = rel_path_for_hash(sha1_copy)
    full = "${repo}/reps/${rel}"

    tmp = "${full}.tmp.${os_getpid_raw()}.0"
    wrc = 0
    if use_zlib == 1 {
        wrc = util.io_write_header_and_body(tmp, storage_hdr, comp, clen)
    } else {
        wrc = util.io_write_header_and_body(tmp, storage_hdr, data, n)
    }
    if wrc != 0 { util.io_remove(tmp); return "" }
    rc = util.io_rename(tmp, full)
    if rc != 0 { util.io_remove(tmp); return "" }

    rc = rep_cache_insert(repo, sha1_copy, rel, n, storage)
    if rc != 0 { return "" }
    return sha1_copy
}

read_blob(repo: string, sha1_hex: string) {
    storage = rep_cache_lookup_storage(repo, sha1_hex)
    if storage == 0 { return "" }
    uncompressed = rep_cache_lookup_uncompressed_size(repo, sha1_hex)
    rel = rel_path_for_hash(sha1_hex)
    full = "${repo}/reps/${rel}"

    raw_ptr, total_len, rerr = fs.read_binary(full)
    if string.length(rerr) > 0 { return "" }
    if total_len < 1 { return "" }

    if storage == STORAGE_RAW {
        return string.substring_n(raw_ptr, total_len, 1, total_len)
    }

    body_compressed = string.substring_n(raw_ptr, total_len, 1, total_len)
    out, _, ierr = zlib.inflate(body_compressed, total_len - 1)
    if string.length(ierr) > 0 { return "" }
    // Silence the unused-warning for `uncompressed` — kept as the
    // historical sanity check on the rep-cache size column.
    uncompressed = uncompressed
    return out
}

// --- test harness ----------------------------------------------------------

expect_int(label: string, got: int, want: int) {
    if got == want {
        println("ok   ${label}: ${got}")
        return 0
    }
    println("FAIL ${label}: got ${got}, want ${want}")
    return 1
}

expect_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}")
    return 1
}

extern system(cmd: string) -> int
rmtree(path: string) { system("rm -rf '${path}'"); return 0 }

main() {
    fails = 0
    pid = os_getpid_raw()
    repo = "/tmp/test_repo_${pid}"
    rmtree(repo)

    // 1. create_repo
    rc = create_repo(repo)
    fails = fails + expect_int("create_repo rc", rc, 0)

    // Double-create rejects.
    rc = create_repo(repo)
    fails = fails + expect_int("create_repo on existing rejects", rc, 1)

    // 2. small blob: RAW storage (too small to benefit from zlib).
    small = "hello"
    sha_small = write_blob(repo, small)
    fails = fails + expect_str("sha1 of 'hello'", sha_small,
        "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d")

    // 3. rep-sharing: second write of same content hits cache.
    sha_small2 = write_blob(repo, small)
    fails = fails + expect_str("rep-share same hash", sha_small2, sha_small)

    // 4. compressible payload: ZLIB storage.
    big = ""
    i = 0
    while i < 500 {
        big = string.concat(big, "this is a sentence. ")
        i = i + 1
    }
    sha_big = write_blob(repo, big)
    fails = fails + expect_int("sha_big is 40-char hex", string.length(sha_big), 40)
    fails = fails + expect_int("big stored as ZLIB", rep_cache_lookup_storage(repo, sha_big), STORAGE_ZLIB)
    fails = fails + expect_int("small stored as RAW", rep_cache_lookup_storage(repo, sha_small), STORAGE_RAW)

    // 5. round-trip both.
    got_small = read_blob(repo, sha_small)
    fails = fails + expect_str("read_blob small", got_small, small)
    got_big = read_blob(repo, sha_big)
    fails = fails + expect_int("read_blob big length", string.length(got_big), string.length(big))
    fails = fails + expect_str("read_blob big content", got_big, big)

    // 6. unknown hash.
    miss = read_blob(repo, "0000000000000000000000000000000000000000")
    fails = fails + expect_str("unknown hash yields empty", miss, "")

    rmtree(repo)

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_repo: OK")
}
