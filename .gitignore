target/
.svn/

# aetherc --emit=lib output — regenerated from *.ae by `aeb`.
# Never hand-edit these; they will be overwritten. See README.md.
**/*_generated.c

# aetherBuild — ignore the symlinks aeb --init creates pointing at
# /home/.../share/aeb/lib/{bash,aether,...}, but track the port-local
# SDK at .aeb/lib/svnae/ which lives in this repo.
/.aeb/lib/*
!/.aeb/lib/svnae/
