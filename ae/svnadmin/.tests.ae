// ae/svnadmin/.tests.ae — admin tool tests
// Integration tests for svnadmin

import std.os
import subr.integration_test

main() {
    s = integration_test.suite("svnadmin")
        .set_description("Repository admin: create, dump, load, verify")
        .add("ae/svnadmin/test_svnadmin.sh")
        .add("ae/svnadmin/test_hash_algo.sh")
        .set_jobs(2)

    integration_test.run_and_exit(s)
}
