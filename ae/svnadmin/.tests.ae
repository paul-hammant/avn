// ae/svnadmin/.tests.ae
// Test suite for repository administration
//
// Declares integration tests for repo creation, dump, load, etc.

import std.os
import subr.integration_test (test_suite_new, test_suite_add, test_suite_set_jobs, test_suite_run_and_exit)

main() {
    suite = test_suite_new("svnadmin repository tool")

    test_suite_add(suite, "ae/svnadmin/test_svnadmin.sh")     // create, dump, load
    test_suite_add(suite, "ae/svnadmin/test_hash_algo.sh")    // hash algorithm selection

    test_suite_set_jobs(suite, 2)
    test_suite_run_and_exit(suite)
}
