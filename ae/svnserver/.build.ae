import build
import aether
import aether (source, output, regen, extra_source, link_flag)

main() {
    b = build.start()
    aether.program(b) {
        source("main.ae")
        output("aether-svnserver")
        link_flag("-lsqlite3")
        link_flag("-lz")
        link_flag("-lssl")
        link_flag("-lcrypto")
        extra_source("../../contrib/sqlite/aether_sqlite.c")
        regen("../../ae/ffi/openssl/crypto_helpers.ae")
        regen("../../ae/subr/io.ae")
        regen("../../ae/subr/binbuf.ae")
        regen("../../ae/fs_fs/tree_builder.ae")
        regen("../../ae/fs_fs/txn.ae")
        regen("../../ae/subr/gintarr.ae")
        regen("../../ae/fs_fs/rebuild.ae")
        regen("../../ae/fs_fs/pathutil.ae")
        regen("../../ae/fs_fs/rep_store.ae")
        regen("../../ae/fs_fs/rep_store_sec.ae")
        regen("../../ae/fs_fs/count_reps.ae")
        regen("../../ae/fs_fs/reppath.ae")
        regen("../../ae/fs_fs/commit_finalise.ae")
        regen("../../ae/fs_fs/branch_spec.ae")
        regen("../../ae/fs_fs/filter.ae")
        regen("../../ae/fs_fs/spec.ae")
        regen("../../ae/fs_fs/dirblob.ae")
        regen("../../ae/fs_fs/format_line.ae")
        regen("../../ae/repos/accessors.ae")
        regen("../../ae/repos/cat.ae")
        regen("../../ae/repos/resolve.ae")
        regen("../../ae/repos/paths_changed.ae")
        regen("../../ae/repos/log.ae")
        regen("../../ae/repos/list_packed.ae")
        regen("../../ae/client/packed.ae")
        regen("../../ae/repos/blobfield.ae")
        regen("../../ae/repos/rev_io.ae")
        regen("../../ae/svnserver/state.ae")
        regen("../../ae/svnserver/auth.ae")
        regen("../../ae/svnserver/json.ae")
        regen("../../ae/svnserver/paths_index.ae")
        regen("../../ae/svnserver/acl.ae")
        regen("../../ae/svnserver/copy_acl.ae")
        regen("../../ae/svnserver/url_parse.ae")
        regen("../../ae/svnserver/redact.ae")
        regen("../../ae/svnserver/info_json.ae")
        regen("../../ae/svnserver/log_json.ae")
        regen("../../ae/svnserver/list_json.ae")
        regen("../../ae/svnserver/acl_resolve.ae")
        regen("../../ae/svnserver/acl_subtree.ae")
        regen("../../ae/svnserver/rev_load.ae")
        regen("../../ae/svnserver/acl_mode.ae")
        regen("../../ae/svnserver/branch_create_parse.ae")
        regen("../../ae/svnserver/copy_parse.ae")
        regen("../../ae/svnserver/commit_parse.ae")
        regen("../../ae/svnserver/based_on_check.ae")
        regen("../../ae/svnserver/handle_repo_rev.ae")
        regen("../../ae/svnserver/dispatch.ae")
        regen("../../ae/svnserver/respond.ae")
        regen("../../ae/svnserver/handler_info.ae")
        regen("../../ae/svnserver/handler_log.ae")
        regen("../../ae/svnserver/handler_rev_info.ae")
        regen("../../ae/svnserver/handler_rev_cat.ae")
        regen("../../ae/svnserver/handler_rev_list.ae")
        regen("../../ae/svnserver/handler_rev_paths.ae")
        regen("../../ae/svnserver/handler_rev_hashes.ae")
        regen("../../ae/svnserver/handler_rev_acl.ae")
