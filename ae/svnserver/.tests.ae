// ae/svnserver/.tests.ae — HTTP server tests
// Integration tests for aether-svnserver

import std.os
import subr.integration_test

main() {
    s = integration_test.suite("HTTP server")
        .set_description("aether-svnserver: JSON metadata, HTTP verbs, wire protocol")
        .add("ae/svnserver/test_server.sh")
        .add("ae/svnserver/test_rest_put.sh")
        .set_jobs(2)

    integration_test.run_and_exit(s)
}
