// ae/svnserver/.tests.ae
// Test suite for HTTP server implementation
//
// Declares integration tests for server operations and wire protocol

import std.os
import subr.integration_test (test_suite_new, test_suite_add, test_suite_set_jobs, test_suite_run_and_exit)

main() {
    suite = test_suite_new("HTTP server (aether-svnserver)")

    test_suite_add(suite, "ae/svnserver/test_server.sh")      // general server operations
    test_suite_add(suite, "ae/svnserver/test_rest_put.sh")    // PUT request handling

    test_suite_set_jobs(suite, 2)
    test_suite_run_and_exit(suite)
}
