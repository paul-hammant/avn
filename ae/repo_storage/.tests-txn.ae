import build
import aether
import aether (source, output, regen, link_flag)

main() {
    b = build.start()
    aether.program_test(b) {
        source("test_txn.ae")
        output("test_txn")
        link_flag("-laether_sqlite")
        link_flag("-lsqlite3")
        link_flag("-lz")
        link_flag("-lssl")
        link_flag("-lcrypto")
        regen("../../ae/util/io.ae")
        regen("../../ae/util/binbuf.ae")
        regen("../../ae/repo_storage/tree_builder.ae")
        regen("../../ae/repo_storage/txn.ae")
        regen("../../ae/util/gintarr.ae")
        regen("../../ae/repo_storage/rebuild.ae")
        regen("../../ae/repo_storage/pathutil.ae")
        regen("../../ae/repo_storage/rep_store.ae")
        regen("../../ae/repo_storage/rep_store_sec.ae")
        regen("../../ae/repo_storage/count_reps.ae")
        regen("../../ae/repo_storage/reppath.ae")
        regen("../../ae/repo_storage/dirblob.ae")
        regen("../../ae/repo_storage/format_line.ae")
        regen("../../ae/repos/rev_io.ae")
        regen("../../ae/repos/blobfield.ae")
        regen("../../ae/ffi/openssl/crypto_helpers.ae")
    }
}
