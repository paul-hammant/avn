import build
import aether
import aether (source, output, regen, link_flag)

main() {
    b = build.start()
    aether.program_test(b) {
        source("test_pristine.ae")
        output("test_wc_pristine")
        link_flag("-laether_sqlite")
        link_flag("-lsqlite3")
        link_flag("-lz")
        link_flag("-lssl")
        link_flag("-lcrypto")
        regen("../../ae/wc/db_accessors.ae")
        regen("../../ae/wc/db_open.ae")
        regen("../../ae/wc/db_schema.ae")
        regen("../../ae/wc/db_nodes.ae")
        regen("../../ae/wc/db_node_packed.ae")
        regen("../../ae/wc/pristine_path.ae")
        regen("../../ae/wc/pristine.ae")
        regen("../../ae/fs_fs/rep_store.ae")
        regen("../../ae/fs_fs/rep_store_sec.ae")
        regen("../../ae/fs_fs/reppath.ae")
        regen("../../ae/fs_fs/count_reps.ae")
        regen("../../ae/fs_fs/format_line.ae")
        regen("../../ae/repos/rev_io.ae")
        regen("../../ae/repos/blobfield.ae")
        regen("../../ae/subr/io.ae")
        regen("../../ae/subr/binbuf.ae")
        regen("../../ae/ffi/openssl/crypto_helpers.ae")
    }
}
