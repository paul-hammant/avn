// wc.db node + nodelist handle accessors — Aether port of
// ae/wc/db_shim.c's two packed-handle families. Same recipe as
// Round 154 (repos) and Round 155 (ra).
//
// node       — single-record handle: a "<path>\x01<kind>\x01...
//              \x01<state>\x01<conflicted>" string with no
//              leading-count header.
// nodelist   — array handle: "<n>\x02<rec0>\x02<rec1>\x02..." with
//              the same record shape.
//
// Field accessors live in ae/wc/db_node_packed.ae; this file just
// surfaces the public ABI through which db_nodes.ae's get_node /
// list_nodes producers feed into the accessors callers expect.

import std.string

extern aether_wc_node_count       (packed: string) -> int
extern aether_wc_node_path        (packed: string) -> string
extern aether_wc_node_kind        (packed: string) -> int
extern aether_wc_node_base_rev    (packed: string) -> int
extern aether_wc_node_base_sha1   (packed: string) -> string
extern aether_wc_node_state       (packed: string) -> int
extern aether_wc_node_conflicted  (packed: string) -> int

extern aether_wc_node_path_at     (packed: string, i: int) -> string
extern aether_wc_node_kind_at     (packed: string, i: int) -> int
extern aether_wc_node_base_rev_at (packed: string, i: int) -> int
extern aether_wc_node_base_sha1_at(packed: string, i: int) -> string
extern aether_wc_node_state_at    (packed: string, i: int) -> int
extern aether_wc_node_conflicted_at(packed: string, i: int) -> int

// ---- node handle (single-record) -------------------------------

export svnae_wc_node_handle(packed: string) -> ptr {
    if string.length(packed) == 0 { return null }
    return string.copy(packed)
}

export svnae_wc_node_path     (n: ptr) -> string {
    if n == null { return "" }
    return aether_wc_node_path(n)
}
export svnae_wc_node_kind     (n: ptr) -> int {
    if n == null { return 0 - 1 }
    return aether_wc_node_kind(n)
}
export svnae_wc_node_base_rev (n: ptr) -> int {
    if n == null { return 0 - 1 }
    return aether_wc_node_base_rev(n)
}
export svnae_wc_node_base_sha1(n: ptr) -> string {
    if n == null { return "" }
    return aether_wc_node_base_sha1(n)
}
export svnae_wc_node_state    (n: ptr) -> int {
    if n == null { return 0 - 1 }
    return aether_wc_node_state(n)
}
export svnae_wc_node_conflicted(n: ptr) -> int {
    if n == null { return 0 }
    return aether_wc_node_conflicted(n)
}
export svnae_wc_node_free     (n: ptr) { return 0 }

// ---- nodelist handle ------------------------------------------

export svnae_wc_nodelist_handle(packed: string) -> ptr {
    if string.length(packed) == 0 { return null }
    return string.copy(packed)
}

export svnae_wc_nodelist_count    (L: ptr) -> int {
    if L == null { return 0 }
    return aether_wc_node_count(L)
}
export svnae_wc_nodelist_path     (L: ptr, i: int) -> string {
    if L == null { return "" }
    return aether_wc_node_path_at(L, i)
}
export svnae_wc_nodelist_kind     (L: ptr, i: int) -> int {
    if L == null { return 0 - 1 }
    return aether_wc_node_kind_at(L, i)
}
export svnae_wc_nodelist_base_rev (L: ptr, i: int) -> int {
    if L == null { return 0 - 1 }
    return aether_wc_node_base_rev_at(L, i)
}
export svnae_wc_nodelist_base_sha1(L: ptr, i: int) -> string {
    if L == null { return "" }
    return aether_wc_node_base_sha1_at(L, i)
}
export svnae_wc_nodelist_state    (L: ptr, i: int) -> int {
    if L == null { return 0 - 1 }
    return aether_wc_node_state_at(L, i)
}
export svnae_wc_nodelist_conflicted(L: ptr, i: int) -> int {
    if L == null { return 0 }
    return aether_wc_node_conflicted_at(L, i)
}
export svnae_wc_nodelist_free     (L: ptr) { return 0 }

main() {
    println("ae/wc/db_accessors.ae is a library; not meant to run standalone")
}
