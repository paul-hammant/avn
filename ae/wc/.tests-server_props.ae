import build
import bash
import bash (script, pre_command, post_command)
import svnae
import svnae (svn_server)

main() {
    b = build.start()
    build.dep(b, "ae/svn")
    build.dep(b, "ae/svnserver")
    bash.test(b) {
        svn_server("test_server_props", "9460")
        script("test_server_props.sh")
    }
}
