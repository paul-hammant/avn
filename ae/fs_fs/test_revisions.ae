// Phase 3.2: revisions and node-revs on the content-addressable blob store.
//
// Commits an initial tree, reads a file back by (rev, path), commits a
// second revision with a modified file, verifies both revisions still
// read correctly (immutability), and checks that unchanged files in rev2
// are rep-shared with rev1 (same SHA-1 → exactly one .rep file on disk).
//
// On-disk layout (see ae/fs_fs/shim.c for the shim-level helpers):
//
//   $repo/
//     format, reps/, rep-cache.db     -- unchanged from Phase 3.1
//     head                            -- "<N>\n" where N is current head rev
//     revs/000000, revs/000001, ...   -- each holds "<sha1>\n" pointing
//                                        at the revision blob under reps/
//
// Revision blob format (plain text):
//     root: <sha1 of the root directory blob>
//     prev: <N-1 or 0>
//     author: <name>
//     date:   <ISO8601 UTC>
//     log:    <single line>
//
// Directory blob format (one line per entry, sorted by name):
//     <kind> <sha1> <name>
// kind = 'f' (file) or 'd' (directory).
//
// Since both formats are line-oriented ASCII, they pass through Aether's
// strlen-based string pipeline safely. File contents, which can be
// arbitrary bytes, always travel through svnae_buf handles (ptr) —
// never through Aether strings.

import std.fs
import std.os
import std.string

// --- externs from subr shims ------------------------------------------------

extern svnae_sha1_hex(data: string, data_len: int) -> string
extern svnae_checksum_free_hex(buf: string)

extern svnae_zlib_deflate(data: string, data_len: int, level: int) -> ptr
extern svnae_zlib_inflate_offset(base: string, offset: int, data_len: int, expected_out: int) -> ptr
extern svnae_buf_length(b: ptr) -> int
extern svnae_buf_data(b: ptr) -> string
extern svnae_buf_free(b: ptr)
extern svnae_write_header_and_buf(path: string, header: string, buf: ptr) -> int

extern aether_io_write_atomic(path: string, data: string, length: int) -> int
extern svnae_write_header_and_body(path: string, header: string, body: string, body_len: int) -> int
extern aether_io_rename(from: string, to: string) -> int
extern aether_io_is_regular_file(path: string) -> int
extern aether_io_remove(path: string) -> int
extern svnae_getpid() -> int
extern svnae_read_file(path: string, out_len: ptr) -> ptr
extern svnae_read_file_length(b: ptr) -> int
extern svnae_read_file_data(b: ptr) -> string
extern svnae_read_file_free(b: ptr)

extern file_exists(path: string) -> int
extern dir_exists(path: string) -> int

// --- externs from fs_fs/shim.c ---------------------------------------------

extern svnae_fsfs_read_small_file(path: string) -> ptr
extern svnae_fsfs_buf_length(b: ptr) -> int
extern svnae_fsfs_buf_data(b: ptr) -> string
extern svnae_fsfs_buf_free(b: ptr)

extern svnae_fsfs_tree_builder_new() -> ptr
extern svnae_fsfs_tree_builder_add(tb: ptr, path: string, kind: int, content: string, content_len: int) -> int
extern svnae_fsfs_tree_builder_count(tb: ptr) -> int
extern svnae_fsfs_tree_builder_path(tb: ptr, i: int) -> string
extern svnae_fsfs_tree_builder_kind(tb: ptr, i: int) -> int
extern svnae_fsfs_tree_builder_content(tb: ptr, i: int) -> ptr
extern svnae_fsfs_tree_builder_free(tb: ptr)

extern svnae_fsfs_sb_new() -> ptr
