// Tests for ae/subr/checksum.ae. Logic inlined (see AETHER_ISSUES.md #2).
//
// Expected hex values computed by coreutils (md5sum / sha1sum):
//   ""                                                 md5  d41d8cd98f00b204e9800998ecf8427e
//   "abc"                                              md5  900150983cd24fb0d6963f7d28e17f72
//   "abc"                                              sha1 a9993e364706816aba3e25717850c26c9cd0d89d
//   "The quick brown fox jumps over the lazy dog"      sha1 2fd4e1c67a2d28fced849ee1bb76e7391b93eb12

import std.string

// Declare the externs with `string` return type (Aether will emit
// `const char*`; the shim returns `char*` which gcc accepts narrowly).
extern svnae_md5_hex(data: string, data_len: int) -> string
extern svnae_sha1_hex(data: string, data_len: int) -> string
extern svnae_checksum_free_hex(buf: string)

// Note: we return a COPY so the value follows Aether's normal string
// lifetime conventions. The shim's malloc'd buffer is freed right after.
md5_hex(data: string) {
    n = string.length(data)
    raw = svnae_md5_hex(data, n)
    copy = string.concat("", raw)
    svnae_checksum_free_hex(raw)
    return copy
}

sha1_hex(data: string) {
    n = string.length(data)
    raw = svnae_sha1_hex(data, n)
    copy = string.concat("", raw)
    svnae_checksum_free_hex(raw)
    return copy
}

// --- harness ---------------------------------------------------------------

expect_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}:")
    println("  got:  ${got}")
    println("  want: ${want}")
    return 1
}

main() {
    fails = 0

    fails = fails + expect_str("md5 empty",
        md5_hex(""),
        "d41d8cd98f00b204e9800998ecf8427e")

    fails = fails + expect_str("md5 abc",
        md5_hex("abc"),
        "900150983cd24fb0d6963f7d28e17f72")

    fails = fails + expect_str("sha1 abc",
        sha1_hex("abc"),
        "a9993e364706816aba3e25717850c26c9cd0d89d")

    fails = fails + expect_str("sha1 fox",
        sha1_hex("The quick brown fox jumps over the lazy dog"),
        "2fd4e1c67a2d28fced849ee1bb76e7391b93eb12")

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_checksum: OK")
}
