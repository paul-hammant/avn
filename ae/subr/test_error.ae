// Test error chain, defined inline in the same file.
//
// Aether v0.70.0 quirks documented for this port:
//   (1) User function definitions with typed params AND a `-> Type` return
//       annotation miscount arguments at call sites. Workaround: omit the
//       return annotation — Aether infers it correctly. Use types on params.
//   (2) `message` is a reserved keyword (actor model) — can't use as a name.
//   (3) No __FILE__/__LINE__; call sites pass them explicitly.
//   (4) Cross-module imports with typed params silently untype them to int
//       (which truncates pointers). Internal helpers are safer in-file for
//       Phase 0; we'll revisit once the module-type system stabilises or
//       we write everything through extern-only module boundaries.

extern svnae_error_create(code: int, msg: string, cause: ptr, file: string, line: int) -> ptr
extern svnae_error_code(err: ptr) -> int
extern svnae_error_message(err: ptr) -> string
extern svnae_error_cause(err: ptr) -> ptr
extern svnae_error_file(err: ptr) -> string
extern svnae_error_line(err: ptr) -> int
extern svnae_error_free(err: ptr)

const ERR_IO_OPEN     = 2001
const ERR_WC_CORRUPT  = 4001
const ERR_BAD_ARG     = 1001
const ERR_FS_CORRUPT  = 5001

err_create(code: int, msg: string, file: string, line: int) {
    return svnae_error_create(code, msg, 0, file, line)
}

err_wrap(cause: ptr, code: int, msg: string, file: string, line: int) {
    return svnae_error_create(code, msg, cause, file, line)
}

err_has_code(err: ptr, c: int) {
    e = err
    while e != 0 {
        if svnae_error_code(e) == c { return 1 }
        e = svnae_error_cause(e)
    }
    return 0
}

err_print_chain(err: ptr) {
    if err == 0 {
        println("(no error)")
        return
    }
    e = err
    while e != 0 {
        c = svnae_error_code(e)
        m = svnae_error_message(e)
        f = svnae_error_file(e)
        l = svnae_error_line(e)
        println("svn-aether: E${c}: ${m}  [${f}:${l}]")
        e = svnae_error_cause(e)
    }
    return
}

main() {
    leaf = err_create(ERR_IO_OPEN, "open failed: permission denied",
                      "test_error.ae", 10)
    mid  = err_wrap(leaf, ERR_WC_CORRUPT,
                    "could not read pristine store",
                    "test_error.ae", 15)
    top  = err_wrap(mid,  ERR_BAD_ARG,
                    "svn status failed for /tmp/wc",
                    "test_error.ae", 20)

    err_print_chain(top)

    if err_has_code(top, ERR_IO_OPEN) == 0 {
        println("FAIL: expected chain to contain ERR_IO_OPEN")
        exit(1)
    }
    if err_has_code(top, ERR_FS_CORRUPT) == 1 {
        println("FAIL: chain should not contain ERR_FS_CORRUPT")
        exit(1)
    }

    svnae_error_free(top)

    // Null-safety: free(0) and accessors on 0 must not crash.
    svnae_error_free(0)
    if svnae_error_code(0) != 0 {
        println("FAIL: code(null) should be 0")
        exit(1)
    }

    println("test_error: OK")
}
