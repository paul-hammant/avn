# Regen recipe for ae/subr/error/error.ae (the error-chain port from
# Round 165 — Aether 0.109's self-referential structs via *Self
# fields retired the C-side linked-list shim).

AETHERC ?= $(abspath $(dir $(lastword $(MAKEFILE_LIST))))/../../../.aether_binaries/build/aetherc

GENERATED := error_generated.c

all: $(GENERATED)

# error.ae: pure malloc/free/struct. No capabilities.
error_generated.c: error.ae
	$(AETHERC) --emit=lib $< $@

.PHONY: all
