// Tests for ae/subr/compress.ae. Logic inlined (AETHER_ISSUES.md #2).

import std.string

extern svnae_zlib_deflate(data: string, data_len: int, level: int) -> ptr
extern svnae_zlib_inflate(data: string, data_len: int, expected_out: int) -> ptr
extern svnae_buf_length(b: ptr) -> int
extern svnae_buf_data(b: ptr) -> string
extern svnae_buf_free(b: ptr)

expect_true(label: string, cond: int) {
    if cond == 1 {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}")
    return 1
}

main() {
    fails = 0

    // A highly compressible ASCII payload — "aaaa...xxxx" repeats. Using
    // only ASCII lets us verify the round-trip via string.equals (no NUL
    // worries on the decoded side).
    src = ""
    i = 0
    while i < 200 {
        src = string.concat(src, "abcdefghij")
        i = i + 1
    }
    orig_len = string.length(src)

    // Sanity: source length.
    fails = fails + expect_true("source is 2000 bytes", orig_len == 2000)

    // Deflate.
    comp = svnae_zlib_deflate(src, orig_len, 6)
    fails = fails + expect_true("deflate handle not null", comp != 0)

    comp_len = svnae_buf_length(comp)
    // Must compress at least 2x for 200 repeats of the same 10-byte seq.
    fails = fails + expect_true("compressed smaller than source", comp_len < orig_len / 2)

    // Inflate back.
    round = svnae_zlib_inflate(svnae_buf_data(comp), comp_len, orig_len)
    fails = fails + expect_true("inflate handle not null", round != 0)

    round_len = svnae_buf_length(round)
    fails = fails + expect_true("round-trip length matches", round_len == orig_len)

    // Content equality — buf_data gives us a C string (NUL-terminated here
    // because our payload is ASCII with no embedded NULs).
    round_str = svnae_buf_data(round)
    fails = fails + expect_true("round-trip bytes match", string.equals(round_str, src))

    svnae_buf_free(comp)
    svnae_buf_free(round)

    println("  source:      ${orig_len} bytes")
    println("  compressed:  ${comp_len} bytes (${(comp_len * 100) / orig_len}%)")

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_compress: OK")
}
