// Tests for std.zlib. Round 176 retired the C-side zlib_*
// shim in favour of std.zlib (docs/stdlib-reference.md "std.zlib"),
// which returns length-aware AetherStrings + explicit byte counts
// instead of opaque buf handles. inflate auto-grows so callers no
// longer need to know the decompressed size in advance.

import std.string
import std.zlib

expect_true(label: string, cond: int) {
    if cond == 1 {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}")
    return 1
}

main() {
    fails = 0

    // A highly compressible ASCII payload — "aaaa...xxxx" repeats.
    src = ""
    i = 0
    while i < 200 {
        src = string.concat(src, "abcdefghij")
        i = i + 1
    }
    orig_len = string.length(src)

    fails = fails + expect_true("source is 2000 bytes", orig_len == 2000)

    comp, comp_len, cerr = zlib.deflate(src, orig_len, 6)
    fails = fails + expect_true("deflate ok", string.length(cerr) == 0)
    fails = fails + expect_true("compressed smaller than source", comp_len < orig_len / 2)

    round, round_len, ierr = zlib.inflate(comp, comp_len)
    fails = fails + expect_true("inflate ok", string.length(ierr) == 0)
    fails = fails + expect_true("round-trip length matches", round_len == orig_len)
    fails = fails + expect_true("round-trip bytes match", string.equals(round, src))

    println("  source:      ${orig_len} bytes")
    println("  compressed:  ${comp_len} bytes (${(comp_len * 100) / orig_len}%)")

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_compress: OK")
}
