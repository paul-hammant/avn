// Tests for ae/subr/io.ae. Inlined for Aether cross-module limits.
//
// Writes a file via atomic_write, reads it back, verifies content, then
// overwrites it with different data and verifies. Cleans up the file at
// the end (and the caller is expected to run this with a writable $TMPDIR).

import std.fs
import std.string

extern aether_io_write_atomic(path: string, data: string, length: int) -> int
extern os_getpid_raw() -> int
extern aether_io_is_regular_file(path: string) -> int
extern aether_io_remove(path: string) -> int

atomic_write(final_path: string, data: string) {
    return aether_io_write_atomic(final_path, data, string.length(data))
}

expect_int(label: string, got: int, want: int) {
    if got == want {
        println("ok   ${label}: ${got}")
        return 0
    }
    println("FAIL ${label}: got ${got}, want ${want}")
    return 1
}

expect_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}:")
    println("  got:  ${got}")
    println("  want: ${want}")
    return 1
}

main() {
    fails = 0
    pid = os_getpid_raw()
    path = "/tmp/svnae_test_io_${pid}.dat"

    // Make sure the file doesn't exist from a prior run.
    aether_io_remove(path)

    // First write.
    content1 = "Hello from Aether! This file was written atomically.\n"
    rc = atomic_write(path, content1)
    fails = fails + expect_int("atomic_write 1 rc", rc, 0)
    fails = fails + expect_int("file exists after write 1", aether_io_is_regular_file(path), 1)

    // Read back. fs.read returns (content, err).
    got1, err1 = fs.read(path)
    fails = fails + expect_str("read back err 1", err1, "")
    fails = fails + expect_str("content 1 matches", got1, content1)

    // Second write overwrites.
    content2 = "Different content the second time around.\n"
    rc = atomic_write(path, content2)
    fails = fails + expect_int("atomic_write 2 rc", rc, 0)

    got2, err2 = fs.read(path)
    fails = fails + expect_str("read back err 2", err2, "")
    fails = fails + expect_str("content 2 matches", got2, content2)

    // Cleanup.
    aether_io_remove(path)
    fails = fails + expect_int("file gone after remove", aether_io_is_regular_file(path), 0)

    // remove() on a non-existent file is idempotent.
    rc = aether_io_remove(path)
    fails = fails + expect_int("remove absent file is ok", rc, 0)

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_io: OK")
}
