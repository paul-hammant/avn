// ae/client/.tests.ae — client library tests
// Integration tests for client library

import std.os
import subr.integration_test

main() {
    s = integration_test.suite("client library")
        .set_description("libsvn_client: API tests")
        .add("ae/client/test_client.sh")
        .set_jobs(1)

    integration_test.run_and_exit(s)
}
