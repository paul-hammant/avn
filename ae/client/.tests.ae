import build
import bash
import bash (script, pre_command, post_command)
import svnae
import svnae (svn_server)

main() {
    b = build.start()
    build.dep(b, "ae/client")
    build.dep(b, "ae/svnserver")
    build.dep(b, "ae/svnserver/.build-seed.ae")
    bash.test(b) {
        svn_server("test_client", "9320")
        script("test_client.sh")
    }
}
