// ae/client/.tests.ae
// Test suite for client library
//
// Declares integration tests for client operations

import std.os
import subr.integration_test (test_suite_new, test_suite_add, test_suite_set_jobs, test_suite_run_and_exit)

main() {
    suite = test_suite_new("client library")

    test_suite_add(suite, "ae/client/test_client.sh")        // client library operations

    test_suite_set_jobs(suite, 1)
    test_suite_run_and_exit(suite)
}
