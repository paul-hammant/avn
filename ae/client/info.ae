// RA endpoint helpers that just GET /repos/<r>/info, parse the JSON,
// and return one scalar field. Round 88 ports them out of
// ae/client/shim.c. Round 100 retires http_get_body in favour of
// get_200 (Aether-side, in http_client.ae).

import std.string

extern url_info(base: string, repo: string) -> string
extern remote_parse_head_rev(body: string) -> int
extern remote_parse_hash_algo(body: string) -> string
extern get_200(url: string) -> string

// Returns the server's current revision number, or -1 on failure
// (transport error, non-200 status, or JSON parse failure).
export remote_head_rev(base_url: string, repo_name: string) -> int {
    body = get_200(url_info(base_url, repo_name))
    if string.length(body) == 0 { return 0 - 1 }
    return remote_parse_head_rev(body)
}

// Returns the server's primary content-address algorithm, or "" on
// failure. Pre-Phase-6.1 servers omit the field; the Aether parser
// defaults to "sha1".
export remote_hash_algo(base_url: string, repo_name: string) -> string {
    body = get_200(url_info(base_url, repo_name))
    if string.length(body) == 0 { return "" }
    return remote_parse_hash_algo(body)
}

main() {
    println("ae/client/info.ae is a library; not meant to run standalone")
}
