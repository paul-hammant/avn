// ae/ra/fetch.ae — per-domain "fetch URL + parse body → packed string"
// helpers. Each pairs one URL builder (urls.ae) with one JSON parser
// (parse.ae). The C-side packed-handle constructors (svnae_ra_log
// etc. in ra/shim.c) call one of these and then wrap the returned
// packed string in svnae_packed_handle_new — no more C-side
// http_get_200 + parse indirection.
//
// Returning "" on any failure matches the C-side semantics: empty
// packed string makes svnae_packed_handle_new return NULL, which
// every existing caller already treats as "miss / give up."

import std.string

extern aether_http_get_200(url: string) -> string
extern aether_ra_http_post_json(url: string, body: string, body_len: int) -> ptr
extern aether_ra_http_response_status(resp: ptr) -> int
extern aether_ra_http_response_body(resp: ptr) -> string
extern aether_ra_http_response_free(resp: ptr)
extern aether_ra_parse_rev_response(body: string) -> int
extern aether_url_info(base: string, repo: string) -> string
extern aether_url_log(base: string, repo: string) -> string
extern aether_url_rev_info(base: string, repo: string, rev: int) -> string
extern aether_url_rev_paths(base: string, repo: string, rev: int) -> string
extern aether_url_rev_list(base: string, repo: string, rev: int, path: string) -> string
extern aether_url_rev_props(base: string, repo: string, rev: int, path: string) -> string
extern aether_url_rev_blame(base: string, repo: string, rev: int, path: string) -> string
extern aether_ra_parse_log(body: string) -> string
extern aether_ra_parse_paths(body: string) -> string
extern aether_ra_parse_blame(body: string) -> string
extern aether_ra_parse_info_rev(body: string) -> string
extern aether_ra_parse_props(body: string) -> string
extern aether_ra_parse_list(body: string) -> string

// Skip leading '/' so the URL the server sees doesn't double up its
// own /repos/<r>/rev/<n>/ prefix. Matches what http_get_200 callers
// in shim.c used to do at the boundary.
strip_leading_slash_(p: string) -> string {
    if string.length(p) == 0 { return p }
    if string.char_at(p, 0) != 47 { return p }   // '/'
    return string.substring(p, 1, string.length(p))
}

export aether_ra_log_packed(base: string, repo: string) -> string {
    body = aether_http_get_200(aether_url_log(base, repo))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_log(body)
}

export aether_ra_paths_packed(base: string, repo: string, rev: int) -> string {
    body = aether_http_get_200(aether_url_rev_paths(base, repo, rev))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_paths(body)
}

export aether_ra_blame_packed(base: string, repo: string, rev: int, path: string) -> string {
    p = strip_leading_slash_(path)
    body = aether_http_get_200(aether_url_rev_blame(base, repo, rev, p))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_blame(body)
}

export aether_ra_info_packed(base: string, repo: string, rev: int) -> string {
    body = aether_http_get_200(aether_url_rev_info(base, repo, rev))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_info_rev(body)
}

export aether_ra_props_packed(base: string, repo: string, rev: int, path: string) -> string {
    p = strip_leading_slash_(path)
    body = aether_http_get_200(aether_url_rev_props(base, repo, rev, p))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_props(body)
}

export aether_ra_list_packed(base: string, repo: string, rev: int, path: string) -> string {
    p = strip_leading_slash_(path)
    body = aether_http_get_200(aether_url_rev_list(base, repo, rev, p))
    if string.length(body) == 0 { return "" }
    return aether_ra_parse_list(body)
}

// POST `body` (JSON) to `url`, expect HTTP <expected_status>, parse
// rev from response. Returns -1 on any failure (transport, wrong
// status, parse error). Shared by:
//   - copy_branch.ae   (server-side copy / branch_create POSTs)
//   - svnae_ra_commit_finish  (commit POST, in ra/shim.c)
// Round 102 retired the C-side http_post_json + take_body helpers
// in favour of this single shared post-and-parse-rev pipeline.
export aether_ra_post_for_rev(url: string, body: string, expected_status: int) -> int {
    resp = aether_ra_http_post_json(url, body, string.length(body))
    if resp == null { return 0 - 1 }
    status = aether_ra_http_response_status(resp)
    if status != expected_status {
        aether_ra_http_response_free(resp)
        return 0 - 1
    }
    body_str = aether_ra_http_response_body(resp)
    rev = aether_ra_parse_rev_response(body_str)
    aether_ra_http_response_free(resp)
    return rev
}

main() {
    println("ae/ra/fetch.ae is a library; not meant to run standalone")
}
