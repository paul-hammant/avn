import build
import bash
import bash (script, pre_command, post_command)
import svnae
import svnae (svn_server_with_token)

main() {
    b = build.start()
    build.dep(b, "ae/svn")
    build.dep(b, "ae/svnadmin")
    build.dep(b, "ae/svnserver")
    bash.test(b) {
        svn_server_with_token("test_acl_write", "9550", "test-super-token-7-2")
        script("test_acl_write.sh")
    }
}
