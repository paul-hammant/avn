        regen("../../ae/client/info.ae")
        regen("../../ae/client/fetch.ae")
        regen("../../ae/subr/io.ae")
        regen("../../ae/subr/binbuf.ae")
        regen("../../ae/working_copy/db_accessors.ae")
        regen("../../ae/working_copy/db_open.ae")
        regen("../../ae/working_copy/db_schema.ae")
        regen("../../ae/working_copy/db_nodes.ae")
        regen("../../ae/working_copy/db_node_packed.ae")
        regen("../../ae/working_copy/pristine_path.ae")
        regen("../../ae/working_copy/pristine.ae")
        regen("../../ae/working_copy/checkout.ae")
        regen("../../ae/working_copy/wc_accessors.ae")
        regen("../../ae/working_copy/status.ae")
        regen("../../ae/working_copy/status_packed.ae")
        regen("../../ae/working_copy/ignore.ae")
        regen("../../ae/working_copy/mutate.ae")
        regen("../../ae/working_copy/commit.ae")
        regen("../../ae/subr/rtree/rtree.ae")
        regen("../../ae/subr/gintarr.ae")
        regen("../../ae/working_copy/update.ae")
        regen("../../ae/working_copy/update_apply.ae")
        regen("../../ae/working_copy/update_walk.ae")
        regen("../../ae/working_copy/revert.ae")
        regen("../../ae/working_copy/diff.ae")
        regen("../../ae/working_copy/props.ae")
