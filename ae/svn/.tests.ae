// ae/svn/.tests.ae — client CLI tests
// Integration tests for svn client command-line interface

import std.os
import subr.integration_test

main() {
    s = integration_test.suite("svn client")
        .set_description("CLI operations: checkout, commit, status, log, merge, branch, blame, verify")
        .add("ae/svn/test_svn.sh")
        .add("ae/svn/test_acl.sh")
        .add("ae/svn/test_acl_write.sh")
        .add("ae/svn/test_acl_cp_follow.sh")
        .add("ae/svn/test_branch_create.sh")
        .add("ae/svn/test_branch_enforce.sh")
        .add("ae/svn/test_branches_phase81.sh")
        .add("ae/svn/test_blame.sh")
        .add("ae/svn/test_verify.sh")
        .add("ae/svn/test_verify_secondaries.sh")
        .set_jobs(4)

    integration_test.run_and_exit(s)
}
