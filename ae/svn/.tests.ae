// Tests still on inline-spawn (no svnae fixture). Each script
// owns its own server lifecycle via tlib_start_server.
//
// Migrated tests live in .tests-<name>.ae alongside this file and
// are discovered by aeb's scan-mode (`aeb` from repo root) but NOT
// by target-mode (`aeb ae/svn`). Until aeb's dir resolution learns
// about .tests-*.ae siblings, run from root for the full suite.

import build
import bash
import bash (script, jobs)

main() {
    b = build.start()
    build.dep(b, "ae/svn")
    build.dep(b, "ae/svnadmin")
    build.dep(b, "ae/svnserver")
    bash.test(b) {
        jobs(8)
        script("test_branches_phase81.sh")
        script("test_svn.sh")
        script("test_verify_secondaries.sh")
        script("test_verify.sh")
    }
}
