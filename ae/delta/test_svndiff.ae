// Tests for svndiff encode/decode round-trip.
//
// Phase 2 exit criterion from svn-to-aether.md: "can round-trip a file
// through delta→apply and recover the original." These tests build the
// op list by hand; xdelta (producing ops from arbitrary source/target)
// comes in the next step.

import std.string

extern svndiff_encoder_new(source_len: int, target_len: int) -> ptr
extern svndiff_encoder_add_op(enc: ptr, action: int, length: int, offset: int) -> int
extern svndiff_encoder_finish(enc: ptr, new_data: @aether string, new_data_len: int) -> (string, int)

extern svndiff_decode_apply(diff: @aether string, diff_len: int, source: @aether string, source_len: int) -> (string, int)

const OP_SOURCE = 0
const OP_TARGET = 1
const OP_NEW    = 2

// Round 184: encoder_finish + decode_apply both return (string, int)
// length-aware AetherString tuples — no buf carrier, no buf_free.
run_case(label: string, source: string, target: string, enc: ptr, new_data: string) {
    ndat = string.length(new_data)
    diff_data, diff_len = svndiff_encoder_finish(enc, new_data, ndat)
    if diff_len == 0 {
        println("FAIL ${label}: encoder_finish returned empty")
        return 1
    }
    got_str, status = svndiff_decode_apply(diff_data, diff_len, source, string.length(source))
    if status == 0 {
        println("FAIL ${label}: decode_apply returned status 0")
        return 1
    }
    got_len = string.length(got_str)
    want_len = string.length(target)

    rc = 0
    if got_len != want_len {
        println("FAIL ${label}: length ${got_len} != ${want_len}")
        rc = 1
    } else if string.equals(got_str, target) == 0 {
        println("FAIL ${label}: content mismatch")
        println("  got:  ${got_str}")
        println("  want: ${target}")
        rc = 1
    } else {
        println("ok   ${label} (${diff_len}B diff; ${got_len}B target)")
    }
    return rc
}

case_identity() {
    src = "Hello, world!\n"
    enc = svndiff_encoder_new(string.length(src), string.length(src))
    svndiff_encoder_add_op(enc, OP_SOURCE, string.length(src), 0)
    return run_case("identity", src, src, enc, "")
}

case_pure_new() {
    src = ""
    tgt = "abc"
    enc = svndiff_encoder_new(0, 3)
    svndiff_encoder_add_op(enc, OP_NEW, 3, 0)
    return run_case("pure new-data", src, tgt, enc, "abc")
}

case_src_prefix_new() {
    src = "ABCDEFGH"
    tgt = "ABCDxyz"
    enc = svndiff_encoder_new(string.length(src), string.length(tgt))
    svndiff_encoder_add_op(enc, OP_SOURCE, 4, 0)
    svndiff_encoder_add_op(enc, OP_NEW,    3, 0)
    return run_case("src prefix + new", src, tgt, enc, "xyz")
}

case_target_rle() {
    // source "", target 8 'x's, built via [new 1 "x"] + [target 7 @0].
    src = ""
    tgt = "xxxxxxxx"
    enc = svndiff_encoder_new(0, 8)
    svndiff_encoder_add_op(enc, OP_NEW,    1, 0)
    svndiff_encoder_add_op(enc, OP_TARGET, 7, 0)
    return run_case("target self-copy RLE", src, tgt, enc, "x")
}

case_word_replace() {
    // "The quick brown fox" -> "The slow brown fox": 4 src + 4 new + 10 src.
    src = "The quick brown fox"
    tgt = "The slow brown fox"
    enc = svndiff_encoder_new(string.length(src), string.length(tgt))
    svndiff_encoder_add_op(enc, OP_SOURCE, 4, 0)    // "The "
    svndiff_encoder_add_op(enc, OP_NEW,    4, 0)    // "slow"
    svndiff_encoder_add_op(enc, OP_SOURCE, 10, 9)   // " brown fox"
    return run_case("word replace", src, tgt, enc, "slow")
}

case_varint_length() {
    // 100 'Z' bytes of new-data forces the length-varint path (>63).
    src = ""
    tgt = ""
    i = 0
    while i < 100 {
        tgt = string.concat(tgt, "Z")
        i = i + 1
    }
    enc = svndiff_encoder_new(0, 100)
    svndiff_encoder_add_op(enc, OP_NEW, 100, 0)
    return run_case("varint length (>63)", src, tgt, enc, tgt)
}

main() {
    fails = 0
    fails = fails + case_identity()
    fails = fails + case_pure_new()
    fails = fails + case_src_prefix_new()
    fails = fails + case_target_rle()
    fails = fails + case_word_replace()
    fails = fails + case_varint_length()

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_svndiff: OK")
}
