import build
import aether
import aether (source, output, regen, link_flag)

main() {
    b = build.start()
    aether.program_test(b) {
        source("test_svndiff.ae")
        output("test_svndiff")
        link_flag("-laether_sqlite")
        link_flag("-lsqlite3")
        link_flag("-lz")
        link_flag("-lssl")
        link_flag("-lcrypto")
        regen("../../ae/delta/svndiff/encoder.ae")
        regen("../../ae/delta/svndiff_decode.ae")
        regen("../../ae/delta/svndiff_encode.ae")
        regen("../../ae/delta/xdelta.ae")
    }
}
