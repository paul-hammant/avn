// Tests for ae/working_copy/db_shim.c.

import std.string

extern os_getpid_raw() -> int
extern system(cmd: string) -> int

extern wc_db_open(wc_root: string) -> ptr
extern wc_db_close(db: ptr)
// 6-param extern. `state` is a reserved keyword (actor model), so we
// use `st` in the Aether-side signature; the C side still exposes both
// the full `state`-named function and the packed alias for back-compat.
extern wc_db_upsert_node(db: ptr, path: string, kind: int, base_rev: int, base_sha1: string, st: int) -> int
extern wc_db_delete_node(db: ptr, path: string) -> int
extern wc_db_node_exists(db: ptr, path: string) -> int
extern wc_db_get_node(db: ptr, path: string) -> ptr

extern wc_node_path(n: ptr) -> string
extern wc_node_kind(n: ptr) -> int
extern wc_node_base_rev(n: ptr) -> int
extern wc_node_base_sha1(n: ptr) -> string
extern wc_node_state(n: ptr) -> int
extern wc_node_free(n: ptr)

extern wc_db_list_nodes(db: ptr) -> ptr
extern wc_nodelist_count(L: ptr) -> int
extern wc_nodelist_path(L: ptr, i: int) -> string
extern wc_nodelist_state(L: ptr, i: int) -> int
extern wc_nodelist_free(L: ptr)

extern wc_db_set_info(db: ptr, key: string, value: string) -> int
extern wc_db_get_info(db: ptr, key: string) -> string

expect_int(label: string, got: int, want: int) {
    if got == want { println("ok   ${label}: ${got}"); return 0 }
    println("FAIL ${label}: got ${got}, want ${want}")
    return 1
}

expect_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("ok   ${label}"); return 0 }
    println("FAIL ${label}: got [${got}] want [${want}]")
    return 1
}

main() {
    fails = 0
    pid = os_getpid_raw()
    wc = "/tmp/test_wcdb_${pid}"
    system("rm -rf ${wc}")
    system("mkdir -p ${wc}")

    db = wc_db_open(wc)
    if db == 0 {
        println("FAIL open"); exit(1)
    }
    println("ok   open (created .svn/wc.db + pristine dir)")

    // Initially empty.
    fails = fails + expect_int("no nodes yet", wc_db_node_exists(db, "README"), 0)

    // Insert a file node. kind=0 (file), state=0 (normal).
    rc = wc_db_upsert_node(db, "README", 0, 1,
                                 "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d", 0)
    fails = fails + expect_int("upsert README", rc, 0)
    fails = fails + expect_int("exists README", wc_db_node_exists(db, "README"), 1)

    // Fetch it back.
    n = wc_db_get_node(db, "README")
    fails = fails + expect_str("node path",     wc_node_path(n),     "README")
    fails = fails + expect_int("node kind=file", wc_node_kind(n),     0)
    fails = fails + expect_int("node base_rev",  wc_node_base_rev(n), 1)
    fails = fails + expect_str("node base_sha1", wc_node_base_sha1(n),
                               "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d")
    fails = fails + expect_int("node state=normal", wc_node_state(n), 0)
    wc_node_free(n)

    // Upsert overwrites. state=1 (added), kind=0 (file).
    wc_db_upsert_node(db, "README", 0, 2,
                            "0000000000000000000000000000000000000000", 1)
    n = wc_db_get_node(db, "README")
    fails = fails + expect_int("after re-upsert state=added", wc_node_state(n), 1)
    fails = fails + expect_int("after re-upsert base_rev=2",  wc_node_base_rev(n), 2)
    wc_node_free(n)

    // Insert more; list gives them sorted.
    wc_db_upsert_node(db, "src",        1, 1, "", 0)
    wc_db_upsert_node(db, "src/main.c", 0, 1,
                            "5e5d5c5b5a59585756555453525150494847464544434241", 0)
    wc_db_upsert_node(db, "LICENSE",    0, 1,
                            "11112222333344445555666677778888999900001111aaaa", 0)

    L = wc_db_list_nodes(db)
    fails = fails + expect_int("list count", wc_nodelist_count(L), 4)
    fails = fails + expect_str("list[0] path", wc_nodelist_path(L, 0), "LICENSE")
    fails = fails + expect_str("list[1] path", wc_nodelist_path(L, 1), "README")
    fails = fails + expect_str("list[2] path", wc_nodelist_path(L, 2), "src")
    fails = fails + expect_str("list[3] path", wc_nodelist_path(L, 3), "src/main.c")
    wc_nodelist_free(L)

    // Delete one.
    wc_db_delete_node(db, "LICENSE")
    fails = fails + expect_int("LICENSE gone", wc_db_node_exists(db, "LICENSE"), 0)

    // Missing node → get_node returns null.
    m = wc_db_get_node(db, "not-there")
    if m != 0 {
        println("FAIL get_node on missing: expected null")
        fails = fails + 1
        wc_node_free(m)
    } else {
        println("ok   get_node on missing returns null")
    }

    // info KV
    wc_db_set_info(db, "url",  "http://localhost:9000/demo")
    wc_db_set_info(db, "repo", "demo")
    v = wc_db_get_info(db, "url")
    fails = fails + expect_str("info url", v, "http://localhost:9000/demo")

    // Unknown key → empty (Round 143: was null pointer).
    v = wc_db_get_info(db, "nope")
    if string.length(v) > 0 {
        println("FAIL info unknown: got [${v}]")
        fails = fails + 1
    } else {
        println("ok   info unknown key is empty")
    }

    // Update (overwrite).
    wc_db_set_info(db, "url", "http://new/demo")
    v = wc_db_get_info(db, "url")
    fails = fails + expect_str("info url updated", v, "http://new/demo")

    wc_db_close(db)

    // Reopen persists.
    db = wc_db_open(wc)
    fails = fails + expect_int("reopen README exists", wc_db_node_exists(db, "README"), 1)
    v = wc_db_get_info(db, "url")
    fails = fails + expect_str("reopen info url", v, "http://new/demo")
    wc_db_close(db)

    system("rm -rf ${wc}")

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s)")
        exit(1)
    }
    println("")
    println("test_wc_db: OK")
}
