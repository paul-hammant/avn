import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")
    build.dep(b, "avn")

    aether.driver_test(b) {
        driver(".test_rest_put_driver.ae")
        output("test_rest_put_driver")

        binary_under_test(b, "svn") {
            path("target/avn/bin/svn")
        }

        fixture_seed(b, "test_put") {
            path("/tmp/avn_aeb_test_put_repo")
            seed_bin("target/avnserver/bin/svnae-seed")
        }
        fixture_server(b, "test_put") {
            bin("target/avnserver/bin/aether-svnserver")
            args("demo $TEST_PUT_PATH 9580 --superuser-token test-put-token")
            port(9580)
            ready_after_ms(1500)
        }
    }
}
