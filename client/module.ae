// client — remote-access (HTTP-to-avnserver) client library.
//
// Phase 3 merge (methodical_extern_removal_plan.md, Round 302).
// Unblocked by aetherc 0.142.0 — selective-import propagation across
// the import boundary now works, so std.http.client's selective
// imports here surface in consumers' compilations transparently.
// (And the 128-decl truncation cap from 0.142.0 also matters at the
// 124-export scale here.)
//
// commit_builder.ae stays separate for now (deferred from this round
// for risk-reduction — it has struct RaCommit which 0.141.0 unblocked,
// so it can fold in next round if needed).

import std.string
import std.config
import std.json
import std.cryptography
import std.intarr
import std.list
import std.io
import ffi.openssl
// std.http.client imported selectively —  would
// collide with our own module name as seen from consumers.
import std.http.client (request, request_free,
                        response_body, response_free,
                        response_header, response_status,
                        send_request, set_body, set_header, set_timeout)


// =============================================================================
// client/accessors.ae
// =============================================================================

// ra (RA-client) accessor families — Aether port of client/shim.c's
// log/paths/blame/info/props/list packed-handle wrappers. Same
// shape as Round 154's repos/accessors.ae: the "handle" is just
// the underlying packed-record AetherString; per-call accessor
// returns are refcounted so we don't need pin_str.



// Parsers (Aether-side, client/packed.ae).






// ---- log handle -------------------------------------------------

remote_log(base_url: string, repo_name: string) -> ptr {
    p = fetch_log(base_url, repo_name)
    if string.length(p) == 0 { return null }
    return string.copy(p)
}
remote_log_count (lg: ptr) -> int {
    if lg == null { return 0 }
    return packed_log_count(lg)
}
remote_log_rev   (lg: ptr, i: int) -> int {
    if lg == null { return 0 - 1 }
    return packed_log_rev(lg, i)
}
remote_log_author(lg: ptr, i: int) -> string {
    if lg == null { return "" }
    return packed_log_author(lg, i)
}
remote_log_date  (lg: ptr, i: int) -> string {
    if lg == null { return "" }
    return packed_log_date(lg, i)
}
remote_log_msg   (lg: ptr, i: int) -> string {
    if lg == null { return "" }
    return packed_log_msg(lg, i)
}
remote_log_free  (lg: ptr) { return 0 }

