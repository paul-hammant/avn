// Repo-root aggregator: every .tests*.ae in the tree as an explicit
// dep. Run via `aeb` (no arg) for the full 32-test suite, or via
// `aeb .tests.ae` for the same suite in target mode.
//
// Without this file, target mode (`aeb` with a directory arg) only
// resolves to the canonical .tests.ae in that dir; sibling
// .tests-<tag>.ae files don't get pulled in. This aggregator wires
// every leaf .tests file together so target-mode discovery works.

import build

main() {
    b = build.start()

    build.dep(b, "client/.tests.ae")
    build.dep(b, "svnadmin/.tests.ae")

    // svnserver — split into two .tests-*.ae files (server, put).
    build.dep(b, "svnserver/.tests-server.ae")
    build.dep(b, "svnserver/.tests-put.ae")

    // svn — all 10 tests on SDK fixtures, one .tests-<tag>.ae each.
    build.dep(b, "svn/.tests-acl.ae")
    build.dep(b, "svn/.tests-acl_cp_follow.ae")
    build.dep(b, "svn/.tests-acl_write.ae")
    build.dep(b, "svn/.tests-blame.ae")
    build.dep(b, "svn/.tests-branch_create.ae")
    build.dep(b, "svn/.tests-branch_enforce.ae")
    build.dep(b, "svn/.tests-branches_phase81.ae")
    build.dep(b, "svn/.tests-svn.ae")
    build.dep(b, "svn/.tests-verify.ae")
    build.dep(b, "svn/.tests-verify_secondaries.ae")

    // working_copy — all 17 tests on SDK fixtures (test_switch's stage-1
    // server is fixture-managed; stage 2 is inline in the script).
    build.dep(b, "working_copy/.tests-switch.ae")
    build.dep(b, "working_copy/.tests-branch.ae")
    build.dep(b, "working_copy/.tests-checkout.ae")
    build.dep(b, "working_copy/.tests-cleanup.ae")
    build.dep(b, "working_copy/.tests-commit.ae")
    build.dep(b, "working_copy/.tests-cp_mv.ae")
    build.dep(b, "working_copy/.tests-ignore.ae")
    build.dep(b, "working_copy/.tests-log_verbose.ae")
    build.dep(b, "working_copy/.tests-merge.ae")
    build.dep(b, "working_copy/.tests-mergeinfo_arith.ae")
    build.dep(b, "working_copy/.tests-merge_reverse.ae")
    build.dep(b, "working_copy/.tests-mutate.ae")
    build.dep(b, "working_copy/.tests-props.ae")
    build.dep(b, "working_copy/.tests-revert_diff.ae")
    build.dep(b, "working_copy/.tests-server_props.ae")
    build.dep(b, "working_copy/.tests-status.ae")
    build.dep(b, "working_copy/.tests-update.ae")
    // working_copy/.tests-cherry_convergence.ae — exploratory; surfaces
    // known avn bugs around server-side branch creation and stale-WC
    // commit. Run on demand: `aeb working_copy/.tests-cherry_convergence.ae`.
    // Documented in TODO.md.

    // Aether-native unit tests (aether.program_test wrappers).
    // Build, run, exit code is the test result. Cover pure helper
    // modules that don't need a server fixture.
    build.dep(b, "util/.tests-error.ae")
    build.dep(b, "util/.tests-checksum.ae")
    build.dep(b, "util/.tests-compress.ae")
    build.dep(b, "util/.tests-io.ae")
    build.dep(b, "util/.tests-sqlite.ae")
    build.dep(b, "working_copy/.tests-db.ae")
    build.dep(b, "working_copy/.tests-pristine.ae")
    build.dep(b, "repo_storage/.tests-txn.ae")
    build.dep(b, "delta/.tests-svndiff.ae")
    build.dep(b, "delta/.tests-xdelta.ae")
}
