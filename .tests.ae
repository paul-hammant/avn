// .tests.ae — root test suite (aetherBuild-compatible)
//
// Master test suite for svn-aether: all 32 integration tests across modules.
//
// Usage:
//   ae build .tests.ae -o /tmp/run_all_tests
//   /tmp/run_all_tests

import std.os
import subr.integration_test

main() {
    // Master test suite
    s = integration_test.suite("svn-aether")
        .set_description("Complete integration test suite (all 32 tests)")

        // Client CLI tests (11)
        .add("ae/svn/test_svn.sh")
        .add("ae/svn/test_acl.sh")
        .add("ae/svn/test_acl_write.sh")
        .add("ae/svn/test_acl_cp_follow.sh")
        .add("ae/svn/test_branch_create.sh")
        .add("ae/svn/test_branch_enforce.sh")
        .add("ae/svn/test_branches_phase81.sh")
        .add("ae/svn/test_blame.sh")
        .add("ae/svn/test_verify.sh")
        .add("ae/svn/test_verify_secondaries.sh")

        // Working copy tests (15)
        .add("ae/wc/test_checkout.sh")
        .add("ae/wc/test_status.sh")
        .add("ae/wc/test_commit.sh")
        .add("ae/wc/test_update.sh")
        .add("ae/wc/test_switch.sh")
        .add("ae/wc/test_revert_diff.sh")
        .add("ae/wc/test_cleanup.sh")
        .add("ae/wc/test_ignore.sh")
        .add("ae/wc/test_props.sh")
        .add("ae/wc/test_cp_mv.sh")
        .add("ae/wc/test_merge.sh")
        .add("ae/wc/test_merge_reverse.sh")
        .add("ae/wc/test_mergeinfo_arith.sh")
        .add("ae/wc/test_log_verbose.sh")
        .add("ae/wc/test_server_props.sh")

        // Server tests (2)
        .add("ae/svnserver/test_server.sh")
        .add("ae/svnserver/test_rest_put.sh")

        // Admin tests (2)
        .add("ae/svnadmin/test_svnadmin.sh")
        .add("ae/svnadmin/test_hash_algo.sh")

        // Client library tests (1)
        .add("ae/client/test_client.sh")

        // Total: 32 tests
        .set_jobs(8)  // auto: nproc / 2

    integration_test.run_and_exit(s)
}
