import build
import aether
import aether (source, output, regen, link_flag)

main() {
    b = build.start()
    aether.program_test(b) {
        source("test_xdelta.ae")
        output("test_xdelta")
        link_flag("-laether_sqlite")
        link_flag("-lsqlite3")
        link_flag("-lz")
        link_flag("-lssl")
        link_flag("-lcrypto")
        regen("../delta/module.ae")
    }
}
