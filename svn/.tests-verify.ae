import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "svn")
    build.dep(b, "svnadmin")
    build.dep(b, "svnserver")
    build.dep(b, "svnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_verify_driver.ae")
        output("test_verify_driver")

        // Stage 1: fixture sha1 server. Stage 2 (sha256) spawned
        // inline by the driver after killing the fixture (via PID).
        binary_under_test(b, "svn") {
            path("target/svn/bin/svn")
        }
        binary_under_test(b, "admin") {
            path("target/svnadmin/bin/svnadmin")
        }
        binary_under_test(b, "server") {
            path("target/svnserver/bin/aether-svnserver")
        }

        fixture_seed(b, "test_verify") {
            path("/tmp/svnae_aeb_test_verify_repo")
            seed_bin("target/svnserver/bin/svnae-seed")
        }
        fixture_server(b, "test_verify") {
            bin("target/svnserver/bin/aether-svnserver")
            args("demo $TEST_VERIFY_PATH 9530")
            port(9530)
            ready_after_ms(1500)
        }
    }
}
