//
// Aether driver for ACL tests. Round 236 canary for token-auth +
// HTTP-header injection shape (X-Svnae-User, X-Svnae-Superuser).
//
// Migrated from svn/test_acl.sh. Uses fixture_server with the
// --superuser-token CLI arg (replacing the bash svn_server_with_token
// SDK setter), env-var-prefixed shell calls (SVN_USER=alice, ...),
// and HTTP requests with custom headers.
//
// Reads $SVN_BIN, $TEST_ACL_PORT, $TEST_ACL_REPO.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string
import std.string (string_contains)
import std.http
import std.http.client

// Closure-extern-ordering workarounds.
extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

// Wrappers — see Round 235 LLM.md note.
http_get_with_user(url: string, user_header: string) -> {
    req = client.request("GET", url)
    client.set_header(req, "X-Svnae-User", user_header)
    client.set_timeout(req, 5)
    resp, err = client.send_request(req)
    client.request_free(req)
    return resp, err
}

http_get_with_super(url: string, token: string) -> {
    req = client.request("GET", url)
    client.set_header(req, "X-Svnae-Superuser", token)
    client.set_timeout(req, 5)
    resp, err = client.send_request(req)
    client.request_free(req)
    return resp, err
}

resp_free(resp: ptr) { client.response_free(resp) }
resp_body(resp: ptr) -> { return client.response_body(resp) }
resp_status(resp: ptr) -> { return client.response_status(resp) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/sh", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    svn_bin = os_getenv("SVN_BIN")
    port    = os_getenv("TEST_ACL_PORT")
    token   = "test-super-token-42"
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    base    = string.concat("http://127.0.0.1:", string.concat(port, "/repos/demo"))

    // Pre-compute shell commands for env-var-prefixed CLI calls.
    // Each closure body would otherwise need string.concat which
    // hits the codegen ordering bug.
    //
    // (B) baseline: alice ls src
    cmd_alice_ls_src = string.concat("SVN_USER=alice ", svn_bin)
    cmd_alice_ls_src = string.concat(cmd_alice_ls_src, " ls ")
    cmd_alice_ls_src = string.concat(cmd_alice_ls_src, url)
    cmd_alice_ls_src = string.concat(cmd_alice_ls_src, " src")

    // (A) super sets ACL on src to +bob -*
    cmd_set_acl = string.concat("SVN_SUPERUSER_TOKEN=", token)
    cmd_set_acl = string.concat(cmd_set_acl, " ")
    cmd_set_acl = string.concat(cmd_set_acl, svn_bin)
    cmd_set_acl = string.concat(cmd_set_acl, " acl set ")
    cmd_set_acl = string.concat(cmd_set_acl, url)
    cmd_set_acl = string.concat(cmd_set_acl, " src '+bob' '-*' >/dev/null")

    // (A) super gets ACL on src
    cmd_get_acl = string.concat("SVN_SUPERUSER_TOKEN=", token)
    cmd_get_acl = string.concat(cmd_get_acl, " ")
    cmd_get_acl = string.concat(cmd_get_acl, svn_bin)
    cmd_get_acl = string.concat(cmd_get_acl, " acl get ")
    cmd_get_acl = string.concat(cmd_get_acl, url)
    cmd_get_acl = string.concat(cmd_get_acl, " src")

    // (F) super-user cat src/main.c
    cmd_super_cat = string.concat("SVN_SUPERUSER_TOKEN=", token)
    cmd_super_cat = string.concat(cmd_super_cat, " ")
    cmd_super_cat = string.concat(cmd_super_cat, svn_bin)
    cmd_super_cat = string.concat(cmd_super_cat, " cat ")
    cmd_super_cat = string.concat(cmd_super_cat, url)
    cmd_super_cat = string.concat(cmd_super_cat, " src/main.c")

    // HTTP URLs for the listing/cat checks
    url_r4_cat_main = string.concat(base, "/rev/4/cat/src/main.c")
    url_r4_list = string.concat(base, "/rev/4/list")

    aeocha.describe(fw, "ACL: read enforcement + super-user bypass") {

        aeocha.it("(B) baseline: alice sees src contents (no ACL yet)") callback {
            out, status, err = sh(cmd_alice_ls_src)
            aeocha.expect_no_spawn_error(fw, err, "spawn ok")
            aeocha.expect_exit(fw, status, 0, "alice ls src exit 0")
            aeocha.expect_stdout_contains(fw, out, "main.c",
                "alice sees src/main.c")
        }

        aeocha.it("(A) super sets +bob -* ACL on src") callback {
            out, status, err = sh(cmd_set_acl)
            aeocha.expect_no_spawn_error(fw, err, "spawn ok")
            aeocha.expect_exit(fw, status, 0, "acl set exit 0")
        }

        aeocha.it("(A) super reads ACL back via 'acl get'") callback {
            out, status, err = sh(cmd_get_acl)
            aeocha.expect_exit(fw, status, 0, "acl get exit 0")
            aeocha.expect_stdout_contains(fw, out, "+bob",
                "acl get shows +bob")
            aeocha.expect_stdout_contains(fw, out, "-*",
                "acl get shows -*")
        }

        aeocha.it("(C) alice gets 404 on src/main.c after ACL set") callback {
            resp, http_err = http_get_with_user(url_r4_cat_main, "alice")
            aeocha.assert_str_eq(fw, http_err, "", "transport ok")
            status = resp_status(resp)
            aeocha.assert_eq(fw, status, 404,
                "alice forbidden on src/main.c → 404")
            resp_free(resp)
        }

        aeocha.it("(C) alice's listing has no 'src' name, has 'hidden' kind") callback {
            resp, http_err = http_get_with_user(url_r4_list, "alice")
            aeocha.assert_str_eq(fw, http_err, "", "transport ok")
            aeocha.expect_http_status(fw, resp, 200, "list 200")
            body = resp_body(resp)
            // alice should NOT see "name":"src"
            has_name_src = string_contains(body, "\"name\":\"src\"")
            aeocha.assert_eq(fw, has_name_src, 0,
                "alice's listing has no 'src' name")
            // She SHOULD see a "kind":"hidden" entry.
            aeocha.expect_http_body_contains(fw, resp,
                "\"kind\":\"hidden\"", "alice sees hidden entry")
            resp_free(resp)
        }

        aeocha.it("(C) bob's listing keeps src name (+bob allows him)") callback {
            resp, http_err = http_get_with_user(url_r4_list, "bob")
            aeocha.assert_str_eq(fw, http_err, "", "transport ok")
            aeocha.expect_http_status(fw, resp, 200, "list 200")
            aeocha.expect_http_body_contains(fw, resp,
                "\"name\":\"src\"", "bob sees src")
            resp_free(resp)
        }

        aeocha.it("(F) super-user cats src/main.c despite ACL") callback {
            out, status, err = sh(cmd_super_cat)
            aeocha.expect_exit(fw, status, 0, "super cat exit 0")
            aeocha.expect_stdout_contains(fw, out, "int main",
                "super sees main() body")
        }
    }

    aeocha.run_summary(fw)
}
