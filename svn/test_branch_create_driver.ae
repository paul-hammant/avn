// Aether driver for `svn branch create` + spec storage.
// Round 250. Migrated from svn/test_branch_create.sh.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string

extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/bash", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    svn_bin = os_getenv("SVN_BIN")
    port    = os_getenv("TEST_BRANCH_CREATE_PORT")
    repo    = os_getenv("TEST_BRANCH_CREATE_REPO")
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    base    = string.concat("http://127.0.0.1:", string.concat(port, "/repos/demo"))
    token   = "b82a-token"

    // (A) non-super create — count "Created branch" should be 0
    non_super = string.concat(svn_bin, " branch create foo ")
    non_super = string.concat(non_super, url)
    non_super = string.concat(non_super, " --from main --include README 2>&1 | grep -c 'Created branch' || true")

    // (B,C) super creates readme-only with --include README. Capture
    // output to a log so we can extract the rev with grep -oE.
    log_readme = "/tmp/svnae_test_bc_readme.log"
    create_readme = string.concat("SVN_SUPERUSER_TOKEN=", token)
    create_readme = string.concat(create_readme, " ")
    create_readme = string.concat(create_readme, svn_bin)
    create_readme = string.concat(create_readme, " branch create readme-only ")
    create_readme = string.concat(create_readme, url)
    create_readme = string.concat(create_readme, " --from main --include README 2>&1 | tee ")
    create_readme = string.concat(create_readme, log_readme)
    cat_readme_log    = "cat /tmp/svnae_test_bc_readme.log"
    grep_readme_count = "grep -c 'Created branch' /tmp/svnae_test_bc_readme.log || true"

    test_head_exists = string.concat("test -f ", repo)
    test_head_exists = string.concat(test_head_exists, "/branches/readme-only/head && echo 1 || echo 0")
    cat_spec_body    = string.concat("cat ", repo)
    cat_spec_body    = string.concat(cat_spec_body, "/branches/readme-only/spec")

    // Extract the rev from the readme-only log and curl /list at that rev.
    extract_rev_readme = "grep -oE 'r[0-9]+' /tmp/svnae_test_bc_readme.log | grep -oE '[0-9]+' | head -1"
    list_readme_rev = string.concat("rev=$(", extract_rev_readme)
    list_readme_rev = string.concat(list_readme_rev, "); curl -s ")
    list_readme_rev = string.concat(list_readme_rev, base)
    list_readme_rev = string.concat(list_readme_rev, "/rev/$rev/list")

    // (D) create feat with --include 'src/**' --include README
    log_feat = "/tmp/svnae_test_bc_feat.log"
    create_feat = string.concat("SVN_SUPERUSER_TOKEN=", token)
    create_feat = string.concat(create_feat, " ")
    create_feat = string.concat(create_feat, svn_bin)
    create_feat = string.concat(create_feat, " branch create feat ")
    create_feat = string.concat(create_feat, url)
    create_feat = string.concat(create_feat, " --from main --include 'src/**' --include README 2>&1 | tee ")
    create_feat = string.concat(create_feat, log_feat)
    grep_feat_count = "grep -c 'Created branch' /tmp/svnae_test_bc_feat.log || true"
    extract_rev_feat = "grep -oE 'r[0-9]+' /tmp/svnae_test_bc_feat.log | grep -oE '[0-9]+' | head -1"
    list_feat_rev = string.concat("rev=$(", extract_rev_feat)
    list_feat_rev = string.concat(list_feat_rev, "); curl -s ")
    list_feat_rev = string.concat(list_feat_rev, base)
    list_feat_rev = string.concat(list_feat_rev, "/rev/$rev/list")
    list_feat_src = string.concat("rev=$(", extract_rev_feat)
    list_feat_src = string.concat(list_feat_src, "); curl -s ")
    list_feat_src = string.concat(list_feat_src, base)
    list_feat_src = string.concat(list_feat_src, "/rev/$rev/list/src")

    // (E) no --include → usage error
    no_include = string.concat("SVN_SUPERUSER_TOKEN=", token)
    no_include = string.concat(no_include, " ")
    no_include = string.concat(no_include, svn_bin)
    no_include = string.concat(no_include, " branch create bad ")
    no_include = string.concat(no_include, url)
    no_include = string.concat(no_include, " --from main 2>&1 | grep -c 'at least one --include' || true")

    // (F) duplicate
    dup = string.concat("SVN_SUPERUSER_TOKEN=", token)
    dup = string.concat(dup, " ")
    dup = string.concat(dup, svn_bin)
    dup = string.concat(dup, " branch create feat ")
    dup = string.concat(dup, url)
    dup = string.concat(dup, " --from main --include README 2>&1 | grep -c 'Created branch' || true")

    // (G) unknown base
    bad_base = string.concat("SVN_SUPERUSER_TOKEN=", token)
    bad_base = string.concat(bad_base, " ")
    bad_base = string.concat(bad_base, svn_bin)
    bad_base = string.concat(bad_base, " branch create x ")
    bad_base = string.concat(bad_base, url)
    bad_base = string.concat(bad_base, " --from no-such --include README 2>&1 | grep -c 'Created branch' || true")

    // (H) branch list
    blist = string.concat(svn_bin, " branch list ")
    blist = string.concat(blist, url)
    list_grep_main      = string.concat(blist, " | grep -c '^main$' || true")
    list_grep_readme    = string.concat(blist, " | grep -c '^readme-only' || true")
    list_grep_feat      = string.concat(blist, " | grep -c '^feat' || true")
    list_grep_readme_g  = string.concat(blist, " | grep -c '^readme-only.*README' || true")
    list_grep_src_glob  = string.concat(blist, " | grep -c 'src/\\*\\*' || true")

    // (I) /info specs
    info_curl = string.concat("curl -s ", base)
    info_curl = string.concat(info_curl, "/info")
    info_specs       = string.concat(info_curl, " | grep -c '\"specs\":{' || true")
    info_specs_ro    = string.concat(info_curl, " | grep -c '\"readme-only\":\\[\"README\"\\]' || true")

    aeocha.describe(fw, "svn branch create + spec storage") {

        aeocha.it("(A) non-super refused — Created branch count = 0") callback {
            out, _, _ = sh(non_super)
            aeocha.expect_stdout_contains(fw, out, "0", "0 created")
        }

        aeocha.it("(B) super creates readme-only") callback {
            _, st, _ = sh(create_readme)
            aeocha.expect_exit(fw, st, 0, "create exit 0")
            out, _, _ = sh(grep_readme_count)
            aeocha.expect_stdout_contains(fw, out, "1", "1 created")
        }

        aeocha.it("(B) head file on disk") callback {
            out, _, _ = sh(test_head_exists)
            aeocha.expect_stdout_contains(fw, out, "1", "head present")
        }

        aeocha.it("(B) spec body is README") callback {
            out, _, _ = sh(cat_spec_body)
            aeocha.expect_stdout_contains(fw, out, "README", "spec = README")
        }

        aeocha.it("(C) readme-only tree at rev has README, no src") callback {
            list, _, _ = sh(list_readme_rev)
            aeocha.expect_stdout_contains(fw, list, "\"name\":\"README\"",
                "tree includes README")
            // no-src check: we use grep-c to count
            no_src = "rev=$(grep -oE 'r[0-9]+' /tmp/svnae_test_bc_readme.log | grep -oE '[0-9]+' | head -1); curl -s "
            no_src = string.concat(no_src, base)
            no_src = string.concat(no_src, "/rev/$rev/list | grep -c '\"name\":\"src\"' || true")
            r2, _, _ = sh(no_src)
            aeocha.expect_stdout_contains(fw, r2, "0", "no src in tree")
        }

        aeocha.it("(D) feat created with src/** + README") callback {
            _, st, _ = sh(create_feat)
            aeocha.expect_exit(fw, st, 0, "feat create exit 0")
            r1, _, _ = sh(grep_feat_count)
            aeocha.expect_stdout_contains(fw, r1, "1", "1 created")
        }

        aeocha.it("(D) feat tree has README and src; src/main.c too") callback {
            list, _, _ = sh(list_feat_rev)
            aeocha.expect_stdout_contains(fw, list, "\"name\":\"README\"",
                "feat root has README")
            aeocha.expect_stdout_contains(fw, list, "\"name\":\"src\"",
                "feat root has src")
            list2, _, _ = sh(list_feat_src)
            aeocha.expect_stdout_contains(fw, list2, "\"name\":\"main.c\"",
                "feat/src has main.c")
        }

        aeocha.it("(E) no --include → usage 'at least one --include'") callback {
            out, _, _ = sh(no_include)
            aeocha.expect_stdout_contains(fw, out, "1", "usage msg present")
        }

        aeocha.it("(F) duplicate branch name refused") callback {
            out, _, _ = sh(dup)
            aeocha.expect_stdout_contains(fw, out, "0", "0 created")
        }

        aeocha.it("(G) unknown base refused") callback {
            out, _, _ = sh(bad_base)
            aeocha.expect_stdout_contains(fw, out, "0", "0 created")
        }

        aeocha.it("(H) branch list has main / readme-only / feat with globs") callback {
            r1, _, _ = sh(list_grep_main)
            aeocha.expect_stdout_contains(fw, r1, "1", "main listed")
            r2, _, _ = sh(list_grep_readme)
            aeocha.expect_stdout_contains(fw, r2, "1", "readme-only listed")
            r3, _, _ = sh(list_grep_feat)
            aeocha.expect_stdout_contains(fw, r3, "1", "feat listed")
            r4, _, _ = sh(list_grep_readme_g)
            aeocha.expect_stdout_contains(fw, r4, "1", "readme-only README glob")
            r5, _, _ = sh(list_grep_src_glob)
            aeocha.expect_stdout_contains(fw, r5, "1", "src/** glob")
        }

        aeocha.it("(I) /info exposes specs map") callback {
            r1, _, _ = sh(info_specs)
            aeocha.expect_stdout_contains(fw, r1, "1", "info has specs")
            r2, _, _ = sh(info_specs_ro)
            aeocha.expect_stdout_contains(fw, r2, "1", "info has readme-only entry")
        }
    }

    aeocha.run_summary(fw)
}
