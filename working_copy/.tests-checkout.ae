import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, env_var, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_checkout_driver.ae")
        output("test_checkout_driver")

        binary_under_test(b, "avn") {
            path("target/avn/bin/avn")
        }

        fixture_seed(b, "test_checkout") {
            path("/tmp/avn_aeb_test_checkout_repo")
            seed_bin("target/avnserver/bin/avn-seed")
        }
        fixture_server(b, "test_checkout") {
            bin("target/avnserver/bin/avnserver")
            args("demo $TEST_CHECKOUT_PATH 9370")
            port(9370)
            ready_after_ms(1500)
        }
    }
}
