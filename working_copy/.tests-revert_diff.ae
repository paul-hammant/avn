import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_revert_diff_driver.ae")
        output("test_revert_diff_driver")

        binary_under_test(b, "avn") {
            path("target/avn/bin/avn")
        }

        fixture_seed(b, "test_revert_diff") {
            path("/tmp/avn_aeb_test_revert_diff_repo")
            seed_bin("target/avnserver/bin/avn-seed")
        }
        fixture_server(b, "test_revert_diff") {
            bin("target/avnserver/bin/avnserver")
            args("demo $TEST_REVERT_DIFF_PATH 9420")
            port(9420)
            ready_after_ms(1500)
        }
    }
}
