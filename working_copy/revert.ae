// avn revert + avn cleanup.
//
// revert: discard local changes by restoring from pristine + reset
// the node's state. State transitions:
//   state=0 (normal): file → overwrite from pristine; dir → no-op
//   state=1 (added):  drop the row, leave file on disk
//   state=2 (deleted): restore from pristine, reset state to 0
//
// cleanup: walk the WC (including .svn/pristine), delete every
// "*.tmp.<digits>" file (aborted atomic-write tmps), plus a stale
// .svn/wc.db-journal if present.

import std.string
import util

// wc.db lifecycle + helpers.
extern wc_db_open(wc_root: string) -> ptr
extern wc_db_close(db: ptr)
extern wc_db_get_node(db: ptr, path: string) -> ptr
extern wc_db_upsert_node(db: ptr, path: string, kind: int, base_rev: int, base_sha1: string, node_state: int) -> int
extern wc_db_delete_node(db: ptr, path: string) -> int

extern wc_node_kind(n: ptr) -> int
extern wc_node_state(n: ptr) -> int
extern wc_node_base_rev(n: ptr) -> int
extern wc_node_base_sha1(n: ptr) -> string
extern wc_node_free(n: ptr)

// Pristine store.
extern wc_pristine_get(wc_root: string, sha1: string) -> string
extern wc_pristine_size(wc_root: string, sha1: string) -> int

// IO helpers.

// ---- revert ---------------------------------------------------------

export wc_revert(wc_root: string, rel_path: string) -> int {
    db = wc_db_open(wc_root)
    if db == null { return 0 - 2 }

    n = wc_db_get_node(db, rel_path)
    if n == null {
        wc_db_close(db)
        return 0 - 1
    }

    kind  = wc_node_kind(n)
    state = wc_node_state(n)
    brev  = wc_node_base_rev(n)
    bsha  = wc_node_base_sha1(n)
    bsha  = string.copy(bsha)
    wc_node_free(n)

    disk = "${wc_root}/${rel_path}"

    if state == 1 {
        // Drop the row. Leave the file in place (becomes unversioned).
        rc = wc_db_delete_node(db, rel_path)
        wc_db_close(db)
        if rc == 0 { return 0 }
        return 0 - 2
    }

    if kind == 1 {
        // Dir: nothing content-wise to restore; just clear any
        // pending-delete state. If state==2, recreate the dir on disk.
        if state == 2 { util.io_mkdir_p(disk) }
        wc_db_upsert_node(db, rel_path, 1, brev, "", 0)
        wc_db_close(db)
        return 0
    }

    // File. Restore content from pristine, reset state to normal.
    psize = wc_pristine_size(wc_root, bsha)
    data  = wc_pristine_get(wc_root, bsha)
    if string.length(data) == 0 {
        wc_db_close(db)
        return 0 - 2
    }
    rc = util.io_write_atomic(disk, data, psize)
    if rc != 0 {
        wc_db_close(db)
        return 0 - 2
    }

    wc_db_upsert_node(db, rel_path, 0, brev, bsha, 0)
    wc_db_close(db)
    return 0
}

// ---- cleanup --------------------------------------------------------

// Does the basename match "*.tmp.<digits>"? That's the exact pattern
// our write_file_atomic uses on its tmp staging files.
is_stale_tmp_(name: string) -> int {
    n = string.length(name)
    sentinel = ".tmp."
    pos = string.index_of(name, sentinel)
    if pos < 0 { return 0 }
    digit_start = pos + 5
    if digit_start >= n { return 0 }
    i = digit_start
    while i < n {
        c = string.char_at(name, i)
        if c < 48 { return 0 }   // < '0'
        if c > 57 { return 0 }   // > '9'
        i = i + 1
    }
    return 1
}

// Walk the directory recursively, deleting every is_stale_tmp_ file.
// Returns the count of files deleted.
walk_and_clean_(root: string) -> int {
    d = util.io_listdir(root)
    if d == null { return 0 }
    count = 0
    n_entries = util.io_listdir_count(d)
    i = 0
    while i < n_entries {
        name = util.io_listdir_name(d, i)
        name = string.copy(name)
        full = "${root}/${name}"
        kind = util.io_stat_kind(full)
        if kind == 2 {
            count = count + walk_and_clean_(full)
        }
        if kind == 1 {
            if is_stale_tmp_(name) == 1 {
                if util.io_unlink(full) == 0 { count = count + 1 }
            }
        }
        i = i + 1
    }
    util.io_listdir_free(d)
    return count
}

export wc_cleanup(wc_root: string) -> int {
    if string.length(wc_root) == 0 { return 0 - 1 }

    // Verify this is a WC by checking for .svn/wc.db.
    wc_db = "${wc_root}/.svn/wc.db"
    if util.io_exists(wc_db) == 0 { return 0 - 1 }

    // is_stale_tmp_ gates what walk_and_clean_ deletes, so we never
    // accidentally touch real wc.db / format / pristine blob files.
    count = walk_and_clean_(wc_root)

    // Stale SQLite rollback-journal: .svn/wc.db-journal. Our WC uses
    // default rollback-journal mode, so the absence of -shm/-wal
    // files is the normal-operation signal. Conservative cleanup:
    // just delete if it's a regular file.
    journal = "${wc_root}/.svn/wc.db-journal"
    if util.io_is_regular_file(journal) == 1 {
        if util.io_unlink(journal) == 0 { count = count + 1 }
    }

    return count
}

main() {
    println("working_copy/revert.ae is a library; not meant to run standalone")
}
