// Recursive remote-tree walker for `svn update` / `svn switch`.
// Calls the RA list/cat accessors and populates a C-side
// remote_tree via the rtree_add_{dir,file} wrappers.
//
// Previously a 28-line recursive C function in working_copy/update_shim.c
// — lifts cleanly once the RA accessors + path-join helper are
// callable from Aether (all already are).

import std.string

extern remote_list(base_url: string, repo_name: string, rev: int, path: string) -> ptr
extern remote_list_count(L: ptr) -> int
extern remote_list_name(L: ptr, i: int) -> string
extern remote_list_kind(L: ptr, i: int) -> string
extern remote_list_free(L: ptr)
extern remote_cat(base_url: string, repo_name: string, rev: int, path: string) -> string
extern remote_free(p: string)

extern path_join_rel(prefix: string, name: string) -> string

extern rtree_add_dir(rt: ptr, path: string)
extern rtree_add_file(rt: ptr, path: string, data: string, data_len: int,
                             wc_root: string)

// Returns 0 on success, -1 on any list/cat failure. wc_root is
// passed through so add_file can compute per-file sha1; Round 140
// retired the C-side TLS pointer that used to thread it through.
export update_walk_remote(wc_root: string,
                           base_url: string, repo: string, rev: int,
                           prefix: string, rt: ptr) -> int {
    L = remote_list(base_url, repo, rev, prefix)
    if L == null { return -1 }

    n = remote_list_count(L)
    result = 0
    i = 0
    while i < n {
        if result == 0 {
            name = remote_list_name(L, i)
            name = string.copy(name)
            kind = remote_list_kind(L, i)
            kind = string.copy(kind)
            rel = path_join_rel(prefix, name)
            rel = string.copy(rel)

            if string.equals(kind, "dir") == 1 {
                rtree_add_dir(rt, rel)
                if update_walk_remote(wc_root, base_url, repo, rev, rel, rt) != 0 {
                    result = -1
                }
            }
            if string.equals(kind, "dir") == 0 {
                data = remote_cat(base_url, repo, rev, rel)
                if string.length(data) == 0 {
                    result = -1
                }
                if result == 0 {
                    rtree_add_file(rt, rel, data, string.length(data), wc_root)
                    remote_free(data)
                }
            }
        }
        i = i + 1
    }
    remote_list_free(L)
    return result
}


main() {
    println("working_copy/update_walk.ae is a library; not meant to run standalone")
}
