import build
import bash
import bash (script, pre_command, post_command)
import svnae
import svnae (svn_server)

main() {
    b = build.start()
    build.dep(b, "svn")
    build.dep(b, "svnserver")
    build.dep(b, "svnserver/.build-seed.ae")
    bash.test(b) {
        // Stage 1 fixture: primary seeded repo on PORT.
        // Stage 2 (alternate repo on PORT+1) is spawned inline by
        // the test — it represents a *different* repo to switch to,
        // not a different fixture role.
        svn_server("test_sw", "9480")
        script("test_switch.sh")
    }
}
