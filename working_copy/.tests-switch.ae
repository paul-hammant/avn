import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, env_var, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "avn")
    build.dep(b, "avnserver")
    build.dep(b, "avnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver(".test_switch_driver.ae")
        output("test_switch_driver")

        binary_under_test(b, "avn") {
            path("target/avn/bin/avn")
        }

        // Two seeded repos + two servers — the multi-fixture shape.
        fixture_seed(b, "test_sw_primary") {
            path("/tmp/avn_aeb_test_sw_primary_repo")
            seed_bin("target/avnserver/bin/avn-seed")
        }
        fixture_seed(b, "test_sw_secondary") {
            path("/tmp/avn_aeb_test_sw_secondary_repo")
            seed_bin("target/avnserver/bin/avn-seed")
        }
        fixture_server(b, "test_sw_primary") {
            bin("target/avnserver/bin/avnserver")
            args("demo $TEST_SW_PRIMARY_PATH 9480")
            port(9480)
            ready_after_ms(1500)
        }
        fixture_server(b, "test_sw_secondary") {
            bin("target/avnserver/bin/avnserver")
            args("demo $TEST_SW_SECONDARY_PATH 9481")
            port(9481)
            ready_after_ms(1500)
        }
    }
}
