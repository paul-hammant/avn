import build
import aether
import aether (driver, output, binary_under_test, fixture_seed, fixture_server,
               path, env_var, repo, seed_bin, bin, args, port, ready_after_ms)

main() {
    b = build.start()
    build.dep(b, "svn")
    build.dep(b, "svnserver")
    build.dep(b, "svnserver/.build-seed.ae")

    aether.driver_test(b) {
        driver("test_switch_driver.ae")
        output("test_switch_driver")

        binary_under_test(b, "svn") {
            path("target/svn/bin/svn")
        }

        // Two seeded repos + two servers — the multi-fixture shape.
        fixture_seed(b, "test_sw_primary") {
            repo("/tmp/svnae_aeb_test_sw_primary_repo")
            seed_bin("target/svnserver/bin/svnae-seed")
        }
        fixture_seed(b, "test_sw_secondary") {
            repo("/tmp/svnae_aeb_test_sw_secondary_repo")
            seed_bin("target/svnserver/bin/svnae-seed")
        }
        fixture_server(b, "test_sw_primary") {
            bin("target/svnserver/bin/aether-svnserver")
            args("demo $TEST_SW_PRIMARY_REPO 9480")
            port(9480)
            ready_after_ms(1500)
        }
        fixture_server(b, "test_sw_secondary") {
            bin("target/svnserver/bin/aether-svnserver")
            args("demo $TEST_SW_SECONDARY_REPO 9481")
            port(9481)
            ready_after_ms(1500)
        }
    }
}
