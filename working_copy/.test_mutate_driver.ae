// Aether driver for svn add/rm test. Round 238.
// Migrated from working_copy/test_mutate.sh.

import contrib.aeocha
import std.os
import std.os (os_getenv)
import std.string

extern list_new() -> ptr
extern list_add_raw(list: ptr, item: ptr) -> int

argv_new() -> { return list_new() }
argv_push(argv: ptr, s: string) { list_add_raw(argv, s) }

sh(cmd: string) -> {
    argv = argv_new()
    argv_push(argv, "-c")
    argv_push(argv, cmd)
    out, status, err = os.run_capture("/bin/bash", argv, null)
    return out, status, err
}

main() {
    fw = aeocha.init()
    svn_bin = os_getenv("SVN_BIN")
    port    = os_getenv("TEST_MUTATE_PORT")
    url     = string.concat("http://127.0.0.1:", string.concat(port, "/demo"))
    wc      = "/tmp/avn_test_mut_wc"

    // prep: checkout + create unversioned file NOTES
    prep = string.concat("rm -rf ", wc)
    prep = string.concat(prep, " && ")
    prep = string.concat(prep, svn_bin)
    prep = string.concat(prep, " checkout ")
    prep = string.concat(prep, url)
    prep = string.concat(prep, " ")
    prep = string.concat(prep, wc)
    prep = string.concat(prep, " >/dev/null && cd ")
    prep = string.concat(prep, wc)
    prep = string.concat(prep, " && echo 'hello from cli' > NOTES")
    prep_out, prep_st, prep_err = sh(prep)

    // status from inside WC, possibly sorted
    cd_status = string.concat("cd ", wc)
    cd_status = string.concat(cd_status, " && ")
    cd_status = string.concat(cd_status, svn_bin)
    cd_status = string.concat(cd_status, " status | sort")

    // svn add NOTES
    add_notes = string.concat("cd ", wc)
    add_notes = string.concat(add_notes, " && ")
    add_notes = string.concat(add_notes, svn_bin)
    add_notes = string.concat(add_notes, " add NOTES")

    // svn rm README
    rm_readme = string.concat("cd ", wc)
    rm_readme = string.concat(rm_readme, " && ")
    rm_readme = string.concat(rm_readme, svn_bin)
    rm_readme = string.concat(rm_readme, " rm README")

    chk_readme = string.concat("test -f ", wc)
    chk_readme = string.concat(chk_readme, "/README && echo present || echo absent")

    cd_status_plain = string.concat("cd ", wc)
    cd_status_plain = string.concat(cd_status_plain, " && ")
    cd_status_plain = string.concat(cd_status_plain, svn_bin)
    cd_status_plain = string.concat(cd_status_plain, " status")

    // svn add of nonexistent — expected to fail nonzero
    add_bogus = string.concat("cd ", wc)
    add_bogus = string.concat(add_bogus, " && ")
    add_bogus = string.concat(add_bogus, svn_bin)
    add_bogus = string.concat(add_bogus, " add does-not-exist 2>/dev/null")

    // DRAFT add+rm round-trip
    draft_dance = string.concat("cd ", wc)
    draft_dance = string.concat(draft_dance, " && echo draft > DRAFT && ")
    draft_dance = string.concat(draft_dance, svn_bin)
    draft_dance = string.concat(draft_dance, " add DRAFT >/dev/null && ")
    draft_dance = string.concat(draft_dance, svn_bin)
    draft_dance = string.concat(draft_dance, " rm DRAFT >/dev/null")

    chk_draft = string.concat("test -f ", wc)
    chk_draft = string.concat(chk_draft, "/DRAFT && echo present || echo absent")

    aeocha.describe(fw, "svn add / rm") {

        aeocha.it("prep: checkout + create NOTES on disk") callback {
            aeocha.expect_exit(fw, prep_st, 0, "prep exit 0")
        }

        aeocha.it("'?' for NOTES before add") callback {
            out, _, _ = sh(cd_status)
            aeocha.expect_stdout_contains(fw, out, "?",
                "? flag present")
            aeocha.expect_stdout_contains(fw, out, "NOTES", "NOTES line")
        }

        aeocha.it("svn add NOTES prints 'A' line") callback {
            out, status, _ = sh(add_notes)
            aeocha.expect_exit(fw, status, 0, "add exit 0")
            aeocha.expect_stdout_contains(fw, out, "A", "A flag present")
            aeocha.expect_stdout_contains(fw, out, "NOTES", "NOTES file")
        }

        aeocha.it("status shows A NOTES after add") callback {
            out, _, _ = sh(cd_status)
            aeocha.expect_stdout_contains(fw, out, "A", "A flag")
            aeocha.expect_stdout_contains(fw, out, "NOTES", "NOTES")
        }

        aeocha.it("svn rm README prints 'D' line") callback {
            out, status, _ = sh(rm_readme)
            aeocha.expect_exit(fw, status, 0, "rm exit 0")
            aeocha.expect_stdout_contains(fw, out, "D", "D flag")
            aeocha.expect_stdout_contains(fw, out, "README", "README")
        }

        aeocha.it("README gone from disk after svn rm") callback {
            out, _, _ = sh(chk_readme)
            aeocha.expect_stdout_contains(fw, out, "absent",
                "README absent")
        }

        aeocha.it("status shows D README") callback {
            out, _, _ = sh(cd_status_plain)
            aeocha.expect_stdout_contains(fw, out, "D", "D flag")
            aeocha.expect_stdout_contains(fw, out, "README", "README line")
        }

        aeocha.it("svn add of nonexistent path fails nonzero") callback {
            _, status, _ = sh(add_bogus)
            aeocha.assert_not_eq(fw, status, 0,
                "add of nonexistent should fail")
        }

        aeocha.it("rm of just-added file: file kept on disk, row dropped") callback {
            _, st, _ = sh(draft_dance)
            aeocha.expect_exit(fw, st, 0, "draft add+rm exit 0")
            out, _, _ = sh(chk_draft)
            aeocha.expect_stdout_contains(fw, out, "present",
                "DRAFT kept on disk")
            status_out, _, _ = sh(cd_status_plain)
            aeocha.expect_stdout_contains(fw, status_out, "?",
                "DRAFT back to ?")
            aeocha.expect_stdout_contains(fw, status_out, "DRAFT",
                "DRAFT in status")
        }
    }

    aeocha.run_summary(fw)
}
