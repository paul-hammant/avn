// Phase 4: libsvn_repos query API.
//
// Builds a repo with three commits and exercises log, cat, list, info,
// head_rev. Commits are built via the Phase 3.3 txn API; queries go
// through the new repos/ shim.

import std.fs
import std.os
import std.string

// --- Phase 3.x plumbing (init + txn commit) -------------------------------



extern os_getpid_raw() -> int
extern dir_exists(path: string) -> int


import contrib.sqlite
import util
import repos
import repo_storage

// --- repos shim externs ----------------------------------------------------



// (returned buffer is freed via rep_free — rep_store_shim owns it)



// --- repo init (same as Phase 3.3) ---------------------------------------

fsfs_init(path: string) {
    if dir_exists(path) == 1 { return 1 }
    merr = fs.mkdir_p(path)
    if string.length(merr) != 0 { return 10 }
    merr = fs.mkdir_p("${path}/reps")
    if string.length(merr) != 0 { return 11 }
    merr = fs.mkdir_p("${path}/revs")
    if string.length(merr) != 0 { return 12 }
    rc = util.io_write_atomic("${path}/format", "svnae-fsfs-1\n", 13)
    if rc != 0 { return rc }
    db, oerr = sqlite.open("${path}/rep-cache.db")
    if string.length(oerr) > 0 { return 3 }
    err = sqlite.exec(db,
        "CREATE TABLE rep_cache (hash TEXT PRIMARY KEY, rel_path TEXT NOT NULL, uncompressed_size INT NOT NULL, storage INT NOT NULL)")
    sqlite.close(db)
    if string.length(err) > 0 { return 4 }

    empty_sha = repo_storage.rep_write_blob(path, "", 0)
    empty_copy = string.concat("", empty_sha)
    rev0 = "root: ${empty_copy}\nprev: 0\nauthor: (init)\ndate: ${os.now_utc_iso8601()}\nlog: initial empty revision\n"
    rev0_sha = repo_storage.rep_write_blob(path, rev0, string.length(rev0))
    rev0_copy = string.concat("", rev0_sha)
    rc = util.io_write_atomic("${path}/revs/000000", "${rev0_copy}\n", string.length(rev0_copy) + 1)
    if rc != 0 { return rc }
    rc = util.io_write_atomic("${path}/head", "0\n", 2)
    if rc != 0 { return rc }
    return 0
}

pad6(n: int) {
    s = "${n}"
    slen = string.length(s)
    if slen >= 6 { return string.concat("", s) }
    return string.concat(string.substring("000000", 0, 6 - slen), s)
}

rev_file_path(repo: string, rev: int) {
    padded = string.concat("", pad6(rev))
    return "${repo}/revs/${padded}"
}

parse_line_value(body: string, key: string) {
    prefix = string.concat(key, ": ")
    n = string.length(body)
    klen = string.length(prefix)
    i = 0
    while i + klen <= n {
        chunk = string.substring(body, i, i + klen)
        if string.equals(chunk, prefix) == 1 {
            j = i + klen
            while j < n {
                c = string.char_at(body, j)
                if c == 10 { break }
                j = j + 1
            }
            return string.substring(body, i + klen, j)
        }
        while i < n {
            c = string.char_at(body, i)
            i = i + 1
            if c == 10 { break }
        }
    }
    return ""
}

rev_root_sha1(repo: string, rev: int) {
    raw = util.io_read_file(rev_file_path(repo, rev))
    if string.length(raw) == 0 { return "" }
    rev_blob_sha1 = string.trim(raw)
    rev_body = repo_storage.rep_read_blob(repo, rev_blob_sha1)
    root = parse_line_value(rev_body, "root")
    root_copy = string.concat("", root)
    repo_storage.rep_free(rev_body)
    return root_copy
}

fsfs_head_rev(repo: string) {
    raw = util.io_read_file("${repo}/head")
    if string.length(raw) == 0 { return -1 }
    t = string.trim(raw)
    if string.try_int(t) == 0 { return -1 }
    return string.get_int(t)
}

commit_txn(repo: string, txn: ptr, author: string, logmsg: string) {
    base_rev = repo_storage.txn_base_rev(txn)
    base_root = rev_root_sha1(repo, base_rev)
    if string.length(base_root) == 0 { return -1 }
    new_root = repo_storage.rebuild_dir(repo, base_root, "", txn)
    if string.length(new_root) == 0 { return -1 }
    new_root = string.copy(new_root)
    prev = fsfs_head_rev(repo)
    next = prev + 1
    rev_body = "root: ${new_root}\nprev: ${prev}\nauthor: ${author}\ndate: ${os.now_utc_iso8601()}\nlog: ${logmsg}\n"
    rev_sha_raw = repo_storage.rep_write_blob(repo, rev_body, string.length(rev_body))
    rev_sha = string.concat("", rev_sha_raw)
    ptr_body = "${rev_sha}\n"
    rc = util.io_write_atomic(rev_file_path(repo, next), ptr_body, string.length(ptr_body))
    if rc != 0 { return -1 }
    rc = util.io_write_atomic("${repo}/head", "${next}\n", string.length("${next}\n"))
    if rc != 0 { return -1 }
    return next
}

// --- test harness ----------------------------------------------------------

expect_int(label: string, got: int, want: int) {
    if got == want { println("ok   ${label}: ${got}"); return 0 }
    println("FAIL ${label}: got ${got}, want ${want}")
    return 1
}

expect_str(label: string, got: string, want: string) {
    if string.equals(got, want) == 1 { println("ok   ${label}"); return 0 }
    println("FAIL ${label}:")
    println("  got:  [${got}]")
    println("  want: [${want}]")
    return 1
}

extern system(cmd: string) -> int
rmtree(path: string) { system("rm -rf '${path}'"); return 0 }

main() {
    fails = 0
    pid = os_getpid_raw()
    repo = "/tmp/test_repos_${pid}"
    rmtree(repo)

    rc = fsfs_init(repo)
    fails = fails + expect_int("init rc", rc, 0)

    // Commit 1: three files and a subdir.
    txn = repo_storage.txn_new(0)
    repo_storage.txn_mkdir(txn, "src")
    repo_storage.txn_add_file(txn, "README",     "Hello\n",                     6)
    repo_storage.txn_add_file(txn, "src/main.c", "int main() { return 0; }\n", 25)
    repo_storage.txn_add_file(txn, "LICENSE",    "Apache-2.0\n",                11)
    r1 = commit_txn(repo, txn, "alice", "first commit")
    repo_storage.txn_free(txn)
    fails = fails + expect_int("commit 1 rev", r1, 1)

    // Commit 2: modify src/main.c.
    txn = repo_storage.txn_new(1)
    repo_storage.txn_add_file(txn, "src/main.c", "int main() { return 42; }\n", 26)
    r2 = commit_txn(repo, txn, "bob", "answer to everything")
    repo_storage.txn_free(txn)
    fails = fails + expect_int("commit 2 rev", r2, 2)

    // Commit 3: delete LICENSE.
    txn = repo_storage.txn_new(2)
    repo_storage.txn_delete(txn, "LICENSE")
    r3 = commit_txn(repo, txn, "alice", "drop license")
    repo_storage.txn_free(txn)
    fails = fails + expect_int("commit 3 rev", r3, 3)

    // --- head_rev ---
    fails = fails + expect_int("head rev", repos.repos_head_rev(repo), 3)

    // --- log ---
    lg = repos.repos_log(repo)
    fails = fails + expect_int("log count", repos.repos_log_count(lg), 4)  // 0..3
    fails = fails + expect_int("log[0] rev", repos.repos_log_rev(lg, 0), 0)
    fails = fails + expect_str("log[0] author", repos.repos_log_author(lg, 0), "(init)")
    fails = fails + expect_str("log[1] author", repos.repos_log_author(lg, 1), "alice")
    fails = fails + expect_str("log[1] msg",    repos.repos_log_msg(lg, 1),    "first commit")
    fails = fails + expect_str("log[2] author", repos.repos_log_author(lg, 2), "bob")
    fails = fails + expect_str("log[2] msg",    repos.repos_log_msg(lg, 2),    "answer to everything")
    fails = fails + expect_str("log[3] author", repos.repos_log_author(lg, 3), "alice")
    fails = fails + expect_str("log[3] msg",    repos.repos_log_msg(lg, 3),    "drop license")
    repos.repos_log_free(lg)

    // --- cat ---
    c = repos.repos_cat(repo, 1, "README")
    fails = fails + expect_str("cat r1 README", c, "Hello\n")
    repo_storage.rep_free(c)

    c = repos.repos_cat(repo, 1, "src/main.c")
    fails = fails + expect_str("cat r1 src/main.c", c, "int main() { return 0; }\n")
    repo_storage.rep_free(c)

    c = repos.repos_cat(repo, 2, "src/main.c")
    fails = fails + expect_str("cat r2 src/main.c", c, "int main() { return 42; }\n")
    repo_storage.rep_free(c)

    // r1 still has the old content (immutability).
    c = repos.repos_cat(repo, 1, "src/main.c")
    fails = fails + expect_str("cat r1 src/main.c (still old)", c, "int main() { return 0; }\n")
    repo_storage.rep_free(c)

    // r3 has no LICENSE.
    c = repos.repos_cat(repo, 3, "LICENSE")
    if c != 0 {
        fails = fails + 1
        println("FAIL cat r3 LICENSE: expected null/missing, got something")
        repo_storage.rep_free(c)
    } else {
        println("ok   cat r3 LICENSE (deleted)")
    }

    // Unknown file.
    c = repos.repos_cat(repo, 3, "nope")
    if c != 0 {
        fails = fails + 1
        println("FAIL cat r3 nope: expected null")
        repo_storage.rep_free(c)
    } else {
        println("ok   cat r3 unknown")
    }

    // --- list ---
    // Root at r1: README, src, LICENSE (sorted: LICENSE, README, src).
    L = repos.repos_list(repo, 1, "/")
    fails = fails + expect_int("list r1 / count", repos.repos_list_count(L), 3)
    fails = fails + expect_str("list r1 /[0] name", repos.repos_list_name(L, 0), "LICENSE")
    fails = fails + expect_str("list r1 /[0] kind", repos.repos_list_kind(L, 0), "file")
    fails = fails + expect_str("list r1 /[1] name", repos.repos_list_name(L, 1), "README")
    fails = fails + expect_str("list r1 /[2] name", repos.repos_list_name(L, 2), "src")
    fails = fails + expect_str("list r1 /[2] kind", repos.repos_list_kind(L, 2), "dir")
    repos.repos_list_free(L)

    // Root at r3: LICENSE removed → README, src. Cover both kinds so a
    // dir/file mis-encoding in list_packed.ae trips two assertions, not
    // just the one at r1 — caught a "dir"/"d" mismatch in round 60.
    L = repos.repos_list(repo, 3, "/")
    fails = fails + expect_int("list r3 / count", repos.repos_list_count(L), 2)
    fails = fails + expect_str("list r3 /[0] name", repos.repos_list_name(L, 0), "README")
    fails = fails + expect_str("list r3 /[0] kind", repos.repos_list_kind(L, 0), "file")
    fails = fails + expect_str("list r3 /[1] name", repos.repos_list_name(L, 1), "src")
    fails = fails + expect_str("list r3 /[1] kind", repos.repos_list_kind(L, 1), "dir")
    repos.repos_list_free(L)

    // Subdir listing.
    L = repos.repos_list(repo, 2, "src")
    fails = fails + expect_int("list r2 src count", repos.repos_list_count(L), 1)
    fails = fails + expect_str("list r2 src[0] name", repos.repos_list_name(L, 0), "main.c")
    fails = fails + expect_str("list r2 src[0] kind", repos.repos_list_kind(L, 0), "file")
    repos.repos_list_free(L)

    // list on a file -> null.
    L = repos.repos_list(repo, 1, "README")
    if L != 0 {
        fails = fails + 1
        println("FAIL list on a file: expected null")
        repos.repos_list_free(L)
    } else {
        println("ok   list on a file is null")
    }

    // --- info ---
    I = repos.repos_info_rev(repo, 2)
    fails = fails + expect_int("info r2 rev",    repos.repos_info_rev_num(I), 2)
    fails = fails + expect_str("info r2 author", repos.repos_info_author(I),  "bob")
    fails = fails + expect_str("info r2 msg",    repos.repos_info_msg(I),     "answer to everything")
    // Date should be a non-empty ISO-8601 timestamp; we don't pin the value.
    dt = repos.repos_info_date(I)
    if string.length(dt) < 10 {
        fails = fails + 1
        println("FAIL info r2 date: too short: [${dt}]")
    } else {
        println("ok   info r2 date: ${dt}")
    }
    repos.repos_info_free(I)

    rmtree(repo)

    if fails > 0 {
        println("")
        println("FAIL: ${fails} case(s) failed")
        exit(1)
    }
    println("")
    println("test_repos: OK")
}
